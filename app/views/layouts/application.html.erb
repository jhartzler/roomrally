<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "RoomRally - Free Party Games for Groups, Youth Groups & Classrooms" %></title>
    
    <%# Primary Meta Tags %>
    <meta name="title" content="<%= content_for(:title) || "RoomRally - Free Party Games for Groups" %>">
    <meta name="description" content="<%= content_for(:description) || "Host fun, safe multiplayer party games like Quiplash for your youth group, classroom, or friends. No app download needed—players join from their phones." %>">
    <meta name="keywords" content="party games, youth group games, classroom games, quiplash alternative, jackbox alternative, group games, ice breaker games, free party games">
    <meta name="author" content="RoomRally">

    <%# Open Graph / Facebook %>
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:title" content="<%= content_for(:title) || "RoomRally - Free Party Games for Groups" %>">
    <meta property="og:description" content="<%= content_for(:description) || "Host fun, safe multiplayer party games for your youth group, classroom, or friends. Players join from their phones—no app needed." %>">
    <meta property="og:image" content="<%= image_url('og-image.png') %>">

    <%# Twitter %>
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="<%= request.original_url %>">
    <meta property="twitter:title" content="<%= content_for(:title) || "RoomRally - Free Party Games for Groups" %>">
    <meta property="twitter:description" content="<%= content_for(:description) || "Host fun, safe multiplayer party games for your youth group, classroom, or friends." %>">
    <meta property="twitter:image" content="<%= image_url('og-image.png') %>">

    <%# Additional SEO %>
    <link rel="canonical" href="<%= request.original_url.split('?').first %>">

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="RoomRally">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="current-player-id" content="<%= current_player&.id %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@1,900&display=swap" rel="stylesheet">
  </head>

  <body class="min-h-screen flex flex-col bg-gradient-to-b from-blue-600 to-indigo-900 font-sans selection:bg-orange-500 selection:text-white">
    <% if flash.any? %>
      <div id="flash" class="fixed top-4 right-4 z-50 space-y-2">
        <% flash.each do |key, value| %>
          <div class="flash <%= key %> <%= key == 'notice' ? 'bg-green-500' : 'bg-red-500' %> text-white px-6 py-4 rounded-xl shadow-lg font-semibold animate-slide-in max-w-md">
            <%= value %>
          </div>
        <% end %>
      </div>
    <% end %>
    <main class="container mx-auto px-4 py-8 flex-grow">
      <%= yield %>
    </main>
    <%= render "shared/footer" unless content_for?(:hide_footer) %>
  </body>
</html>
