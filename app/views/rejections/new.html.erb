<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm" data-controller="modal" data-action="click->modal#closeBackground">
    <div class="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl animate-in zoom-in duration-200">
      <h2 class="text-2xl font-black text-gray-900 mb-4 uppercase tracking-tighter">Reject Response</h2>
      
      <div class="bg-slate-100 p-4 rounded-xl mb-6">
        <p class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-1">Response</p>
        <p class="text-lg font-medium text-slate-800"><%= @response.body %></p>
      </div>

      <%= form_with url: response_rejections_path(@response), method: :post, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :rejection_reason, "Reason for Rejection", class: "block text-sm font-bold text-gray-700 uppercase tracking-wide mb-2" %>
          <%= f.text_area :rejection_reason, 
              placeholder: "e.g., Too inappropriate, Nonsense answer...", 
              class: "w-full border-2 border-slate-200 rounded-xl p-4 text-slate-900 placeholder-slate-400 focus:border-red-500 focus:ring-0 transition-all outline-none resize-none",
              rows: 3,
              autofocus: true %>
        </div>

        <div class="flex gap-3">
          <%= link_to "Cancel", :back, class: "flex-1 py-4 text-center font-bold text-slate-500 hover:text-slate-800 uppercase tracking-wide transition-colors" %>
          <%= f.submit "Reject Response", class: "flex-1 bg-red-500 hover:bg-red-600 active:scale-[0.98] text-white font-black py-4 rounded-xl shadow-lg shadow-red-500/30 transition-all uppercase tracking-tight cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
