<% content_for(:hide_footer, true) %>
<%= turbo_stream_from @room %>

<div class="fixed inset-0 overflow-hidden text-white p-[2vh] flex flex-col bg-gradient-to-b from-blue-600 to-indigo-900 z-40" data-controller="reconnect">
  <div class="max-w-7xl mx-auto text-center w-full flex flex-col flex-1 min-h-0">
    <!-- Header: room name + join info -->
    <div class="mb-[2vh] relative shrink-0">
      <h1 class="text-vh-5xl font-black text-white tracking-tighter drop-shadow-lg text-center">
        <%= @room.display_name %>
      </h1>

      <div class="absolute top-0 right-0 flex items-center gap-[1vh] bg-white/10 backdrop-blur-md rounded-xl px-[1.5vh] py-[0.5vh] border border-white/20">
        <span class="text-vh-sm font-semibold text-white/60 tracking-wide">roomrally.app/play</span>
        <span class="text-vh-lg font-black font-mono tracking-widest text-white"><%= @room.code %></span>
      </div>
    </div>

    <!-- Main Content Area -->
    <div id="stage_content" class="relative flex-1 min-h-0 flex flex-col items-center" data-controller="stage-transition">
      <% if @room.current_game.present? %>
        <% game = @room.current_game %>
        <% game_type_folder = @room.game_type.parameterize.underscore %>
        <% partial_name = "games/#{game_type_folder}/stage_#{game.status}" %>
        <%= render partial_name, room: @room, game: game %>
      <% else %>
        <%= render "rooms/stage_lobby", room: @room %>
      <% end %>
    </div>
  </div>
</div>
