<% content_for(:hide_footer, true) %>
<%= turbo_stream_from @room %>

<div class="min-h-screen text-white p-8">
  <div class="max-w-7xl mx-auto text-center">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-6xl font-black text-white mb-4 tracking-tighter drop-shadow-lg">
        <%= @room.display_name %>
      </h1>
      <div class="inline-block bg-white/10 backdrop-blur-md rounded-3xl px-12 py-6 border border-white/20">
        <p class="text-gray-400 text-xl font-bold tracking-wider mb-2">Room Code</p>
        <p class="text-8xl font-black font-mono tracking-widest"><%= @room.code %></p>
      </div>
    </div>

    <!-- Main Content Area -->
    <div id="stage_content" class="relative">
      <% if @room.current_game.present? %>
        <% if @room.current_game.status == "finished" %>
           <%= render "games/write_and_vote/stage_finished", room: @room, game: @room.current_game %>
        <% elsif @room.current_game.status == "voting" %>
           <%= render "games/write_and_vote/stage_voting", room: @room, game: @room.current_game %>
        <% else %>
           <%# Default to writing/intro %>
           <%= render "games/write_and_vote/stage_writing", room: @room, game: @room.current_game %>
        <% end %>
      <% else %>
        <%= render "rooms/stage_lobby", room: @room %>
      <% end %>
    </div>
  </div>
</div>
