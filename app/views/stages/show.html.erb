<%= turbo_stream_from @room %>

<div class="min-h-screen bg-black text-white p-8">
  <div class="max-w-7xl mx-auto text-center">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-6xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 mb-4">
        Stage View
      </h1>
      <div class="inline-block bg-white/10 backdrop-blur-md rounded-3xl px-12 py-6 border border-white/20">
        <p class="text-gray-400 text-xl font-bold uppercase tracking-wider mb-2">Room Code</p>
        <p class="text-8xl font-black font-mono tracking-widest"><%= @room.code %></p>
      </div>
    </div>

    <!-- Main Content Area -->
    <div id="stage_content" class="relative">
      <% if @room.current_game.present? %>
        <!-- Placeholder for Game View -->
        <div class="p-12 border-2 border-dashed border-gray-700 rounded-3xl">
          <p class="text-3xl text-gray-500">Game in Progress...</p>
        </div>
      <% else %>
        <%= render "rooms/stage_lobby", room: @room %>
      <% end %>
    </div>
  </div>
</div>
