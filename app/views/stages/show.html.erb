<% content_for(:hide_footer, true) %>
<%= turbo_stream_from @room %>

<div class="fixed inset-0 overflow-hidden text-white p-[2vh] flex flex-col bg-gradient-to-b from-blue-600 to-indigo-900 z-40">
  <div class="max-w-7xl mx-auto text-center w-full flex flex-col flex-1 min-h-0">
    <!-- Header: always compact with small corner QR -->
    <div class="mb-[2vh] relative shrink-0">
      <h1 class="text-vh-5xl font-black text-white tracking-tighter drop-shadow-lg text-center">
        <%= @room.display_name %>
      </h1>

      <div class="absolute top-0 right-0 flex items-center gap-2 bg-white/10 backdrop-blur-md rounded-lg px-2 py-1 border border-white/10">
        <div class="bg-white rounded p-0.5">
          <%= qr_code_svg(join_room_url(@room.code), size: 24) %>
        </div>
        <span class="text-xs font-bold font-mono tracking-wider text-white/70"><%= @room.code %></span>
      </div>
    </div>

    <!-- Main Content Area -->
    <div id="stage_content" class="relative flex-1 min-h-0 flex flex-col items-center">
      <% if @room.current_game.present? %>
        <% game = @room.current_game %>
        <% game_type_folder = @room.game_type.parameterize.underscore %>
        <% partial_name = "games/#{game_type_folder}/stage_#{game.status}" %>
        <%= render partial_name, room: @room, game: game %>
      <% else %>
        <%= render "rooms/stage_lobby", room: @room %>
      <% end %>
    </div>
  </div>
</div>
