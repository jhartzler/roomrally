<%# app/views/players/_backstage_player.html.erb %>
<li id="<%= dom_id(player) %>"
    data-controller="player-glow"
    data-player-glow-joined-at-value="<%= player.created_at.to_i %>"
    class="flex items-center justify-between p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-white/10 transition-colors">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold shadow-inner border border-white/10">
      <%= player.name[0].upcase %>
    </div>
    <div>
      <p class="font-bold text-white"><%= player.name %></p>
      <% if player.room.host == player %>
        <span class="text-[10px] uppercase font-bold text-orange-400 tracking-wider">Host</span>
      <% else %>
        <span class="text-[10px] uppercase font-bold text-blue-300 tracking-wider">Player</span>
      <% end %>
    </div>
  </div>
  <% unless player.room.host == player %>
    <div class="flex gap-2">
       <%= button_to "Kick", player_path(player), method: :delete, class: "text-[10px] bg-red-500 hover:bg-red-600 text-white font-bold py-1 px-3 rounded-lg transition-all uppercase tracking-wide", data: { turbo_confirm: "Kick #{player.name}?", turbo_submits_with: "…" } %>
    </div>
  <% end %>
</li>
