<%= turbo_frame_tag dom_id(player) do %>
  <div data-controller="player-card" data-player-card-player-id-value="<%= player.id %>" data-player-card-host-id-value="<%= player.room.host&.id %>">
    <div class="group bg-white/10 backdrop-blur-md rounded-xl p-4 border border-white/20 hover:bg-white/20 transition-all hover:shadow-lg">
      <div class="flex items-center gap-3">
        <div class="bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full w-12 h-12 flex items-center justify-center text-white font-bold text-xl shadow-inner">
          <%= player.name[0].upcase %>
        </div>
        <div class="flex-1">
          <p class="font-bold text-white text-lg"><%= player.name %></p>
          <% if player == player.room.host %>
            <p class="text-xs text-orange-400 font-bold flex items-center gap-1 uppercase tracking-wider">
              <span>👑</span>
              <span>Host</span>
            </p>
          <% else %>
            <p class="text-xs text-blue-200 font-semibold uppercase tracking-wider">Player</p>
          <% end %>
        </div>

        <div data-player-card-target="actions" class="hidden gap-2">
          <%= button_to "Make Host", reassign_host_room_path(player.room.code, player_id: player.id), method: :post, class: "text-[10px] bg-orange-500 hover:bg-orange-600 text-white font-bold py-1 px-2 rounded-lg transition-all uppercase tracking-wide", title: "Make this player the host" %>
          <%= button_to "Kick", player_path(player), method: :delete, class: "text-[10px] bg-red-500 hover:bg-red-600 text-white font-bold py-1 px-2 rounded-lg transition-all uppercase tracking-wide", title: "Remove this player from the room", data: { turbo_confirm: "Are you sure you want to kick #{player.name}?" } %>
        </div>
      </div>
    </div>
  </div>
<% end %>
