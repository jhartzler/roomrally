<%# Reconnect banner — shown only if there's an active room %>
<% if @active_rooms.any? %>
  <% room = @active_rooms.first %>
  <div class="mx-3 mt-3 md:mx-6 md:mt-6 flex items-center gap-3 bg-green-500/10 border border-green-400/20 rounded-xl px-4 py-3">
    <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse shrink-0"></span>
    <p class="text-green-200 text-sm font-medium flex-1 min-w-0 truncate">
      Room <span class="font-black font-mono tracking-wider"><%= room.code %></span> is active
    </p>
    <div class="flex items-center gap-3 shrink-0">
      <%= link_to room_backstage_path(room.code),
            class: "text-green-300 hover:text-white text-xs font-bold transition-colors" do %>
        Backstage →
      <% end %>
      <%= link_to room_stage_path(room.code), target: "_blank",
            class: "hidden sm:inline text-green-300/60 hover:text-green-300 text-xs font-medium transition-colors" do %>
        Stage ↗
      <% end %>
    </div>
  </div>
<% end %>

<div class="p-4 md:p-8">

  <% is_new_user = @game_templates.empty? %>

  <% if is_new_user %>
    <%# ── NEW USER: Onboarding workflow ─── %>
    <header class="mb-6 md:mb-8">
      <h1 class="text-2xl md:text-3xl font-black text-white mb-1">Welcome, <%= current_user.name.split.first %>!</h1>
      <p class="text-blue-200/70 text-sm">Here's how to run your first RoomRally game.</p>
    </header>

    <%# 3-step workflow %>
    <div class="mb-8 md:mb-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 relative">
        <%# Connecting line — desktop only %>
        <div class="hidden md:block absolute top-10 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-gradient-to-r from-orange-500/40 via-blue-400/40 to-blue-400/40"></div>

        <%# Step 1 %>
        <div class="relative bg-white/5 border border-white/10 rounded-2xl p-4 md:p-5">
          <div class="w-8 h-8 rounded-full bg-orange-500 text-white text-sm font-black flex items-center justify-center mb-3 shadow-lg shadow-orange-900/30">1</div>
          <h3 class="font-black text-white text-base mb-1">Pick a game type</h3>
          <p class="text-blue-200/60 text-xs leading-relaxed mb-3">Choose from <%= Room.available_game_types.map { |gt| Room::GAME_DISPLAY_NAMES[gt] || gt }.to_sentence %>. Each uses different content — prompts, trivia, or categories.</p>
          <div class="space-y-1.5">
            <% Room.available_game_types.each do |game_type| %>
              <% info = game_info(game_type) %>
              <div class="flex items-center gap-2 text-xs text-blue-200/70">
                <span><%= info[:emoji] %></span>
                <span class="font-semibold"><%= Room::GAME_DISPLAY_NAMES[game_type] || game_type %></span>
                <span class="text-blue-400/40 hidden sm:inline">·</span>
                <span class="text-blue-300/50 truncate hidden sm:inline"><%= info[:tagline] %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# Step 2 %>
        <div class="relative bg-white/5 border border-white/10 rounded-2xl p-4 md:p-5">
          <div class="w-8 h-8 rounded-full bg-blue-500 text-white text-sm font-black flex items-center justify-center mb-3 shadow-lg shadow-blue-900/30">2</div>
          <h3 class="font-black text-white text-base mb-1">Save a game template</h3>
          <p class="text-blue-200/60 text-xs leading-relaxed mb-3">Name it, choose a game type and settings, and optionally attach a custom content pack. One click to launch later.</p>
          <%= link_to new_game_template_path,
                class: "inline-flex items-center gap-1.5 text-orange-400 hover:text-orange-300 font-bold text-xs transition-colors" do %>
            <%= lucide_icon('plus-circle', class: "w-3.5 h-3.5") %>
            Create your first template
          <% end %>
        </div>

        <%# Step 3 %>
        <div class="relative bg-white/5 border border-white/10 rounded-2xl p-4 md:p-5">
          <div class="w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-black flex items-center justify-center mb-3 shadow-lg shadow-blue-900/30">3</div>
          <h3 class="font-black text-white text-base mb-1">Launch &amp; share the code</h3>
          <p class="text-blue-200/60 text-xs leading-relaxed mb-3">Hit Launch — a 4-letter room code appears. Players enter it on their phones. Project the Stage view for everyone to see.</p>
          <%= link_to host_path,
                class: "inline-flex items-center gap-1.5 text-blue-300 hover:text-white font-bold text-xs transition-colors" do %>
            <%= lucide_icon('play', class: "w-3.5 h-3.5") %>
            Skip ahead — Quick Host
          <% end %>
        </div>
      </div>
    </div>

    <%# Game type explorer %>
    <div>
      <h2 class="text-xs font-bold text-blue-400/60 uppercase tracking-widest mb-3 md:mb-4">Game Types</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
        <% Room.available_game_types.each do |game_type| %>
          <% info = game_info(game_type) %>
          <div class="bg-white/5 border border-white/10 rounded-2xl p-4 md:p-5">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl"><%= info[:emoji] %></span>
              <div>
                <p class="font-black text-white text-sm"><%= Room::GAME_DISPLAY_NAMES[game_type] || game_type %></p>
                <p class="text-[10px] text-blue-400/60 font-mono"><%= info[:player_count] %> · <%= info[:duration] %></p>
              </div>
            </div>
            <p class="text-blue-200/60 text-xs leading-relaxed mb-3"><%= info[:description] %></p>
            <div class="space-y-1.5">
              <% info[:how_it_works]&.each_with_index do |step, i| %>
                <div class="flex items-start gap-2 text-xs text-blue-300/60">
                  <span class="shrink-0 text-blue-500/60 font-bold mt-px"><%= i + 1 %>.</span>
                  <span><%= step %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  <% else %>
    <%# ── RETURNING USER: Quick launch ─── %>
    <header class="mb-6 md:mb-8">
      <h1 class="text-2xl md:text-3xl font-black text-white mb-1">Welcome back, <%= current_user.name.split.first %>!</h1>
      <p class="text-blue-200/70 text-sm">Ready to make some memories?</p>
    </header>

    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-bold text-blue-400/60 uppercase tracking-widest">Your Games</h2>
        <%= link_to game_templates_path, class: "text-xs text-blue-300 hover:text-white font-bold transition-colors" do %>See all →<% end %>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @game_templates.first(6).each do |template| %>
          <%= render "game_templates/template_card", template: template %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
