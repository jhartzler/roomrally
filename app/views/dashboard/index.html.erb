<div class="min-h-screen p-6 md:p-12 font-sans text-white">
  <header class="max-w-5xl mx-auto mb-10">
    <%= link_to root_path, class: "group flex items-center gap-2 text-blue-200 hover:text-white transition-colors font-bold mb-6 w-fit" do %>
      <div class="p-2 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors border border-white/10">
        <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
      </div>
      <span>Back to Home</span>
    <% end %>

    <h1 class="text-4xl font-black text-white drop-shadow-lg mb-2">
      Welcome back, <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-yellow-400"><%= current_user.name %></span>
    </h1>
    <p class="text-blue-200 font-bold tracking-widest text-sm">Ready to make some memories?</p>
  </header>

  <section class="max-w-5xl mx-auto mb-8">
    <details class="bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 overflow-hidden">
      <summary class="px-6 py-4 cursor-pointer text-blue-200 font-bold hover:text-white transition-colors flex items-center gap-2">
        <span class="text-lg">New to RoomRally?</span>
        <span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-0.5 rounded-full border border-blue-400/20">Quick Guide</span>
      </summary>
      <div class="px-6 pb-6 pt-2">
        <ol class="space-y-3 text-sm">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-orange-500/20 text-orange-300 rounded-full flex items-center justify-center text-xs font-bold border border-orange-400/20">1</span>
            <div>
              <span class="text-white font-bold">Create a room</span>
              <span class="text-blue-200/70"> — pick a game type and hit Create</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-orange-500/20 text-orange-300 rounded-full flex items-center justify-center text-xs font-bold border border-orange-400/20">2</span>
            <div>
              <span class="text-white font-bold">Share the code</span>
              <span class="text-blue-200/70"> — players visit the site and enter the 4-letter code on their phones</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-orange-500/20 text-orange-300 rounded-full flex items-center justify-center text-xs font-bold border border-orange-400/20">3</span>
            <div>
              <span class="text-white font-bold">Open the Stage view</span>
              <span class="text-blue-200/70"> — project it on a big screen or share your screen — this is what the audience sees</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-orange-500/20 text-orange-300 rounded-full flex items-center justify-center text-xs font-bold border border-orange-400/20">4</span>
            <div>
              <span class="text-white font-bold">Run from Backstage</span>
              <span class="text-blue-200/70"> — control the game, moderate responses, and advance rounds from your backstage panel</span>
            </div>
          </li>
        </ol>
        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-xs font-bold text-blue-300 mb-2">Quick tips</p>
          <ul class="text-xs text-blue-200/60 space-y-1">
            <li>Test with a second browser tab as a player before your event</li>
            <li>Use Stage-Only mode for in-person events without phones</li>
          </ul>
        </div>
      </div>
    </details>
  </section>

  <main class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
    <% if @active_rooms.any? %>
      <div class="md:col-span-2">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
          <span>Active Rooms & Games</span>
          <span class="bg-orange-500 text-white text-xs px-2 py-0.5 rounded-full"><%= @active_rooms.count %></span>
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @active_rooms.each do |room| %>
            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/10 flex flex-col justify-between h-full hover:bg-white/15 transition-all group">
              <div>
                <div class="flex justify-between items-start mb-2">
                   <h4 class="font-black text-2xl font-mono text-white tracking-wider group-hover:scale-105 transition-transform"><%= room.code %></h4>
                   <span class="px-2 py-0.5 bg-white/20 text-blue-100 text-xs font-bold rounded border border-white/10"><%= room.status %></span>
                </div>
                <p class="text-sm font-bold text-blue-200 mb-1 tracking-wide"><%= room.display_name %></p>
                <p class="text-[10px] text-blue-300 mb-4 font-mono"><%= time_ago_in_words(room.created_at) %> ago</p>
              </div>

               <div class="grid grid-cols-2 gap-2 mt-auto">
                 <%= link_to room_backstage_path(room.code), class: "flex items-center justify-center gap-1.5 py-2 px-3 bg-blue-600/50 hover:bg-blue-600 text-white font-bold text-sm rounded-lg transition-colors border border-blue-400/30" do %>
                   <%= lucide_icon('settings', class: "w-4 h-4") %>
                   Manage
                 <% end %>
                 <%= link_to room_stage_path(room.code), target: "_blank", class: "flex items-center justify-center gap-1.5 py-2 px-3 bg-white/10 hover:bg-white/20 text-white font-bold text-sm rounded-lg transition-colors border border-white/10" do %>
                   <%= lucide_icon('external-link', class: "w-4 h-4") %>
                   Stage
                 <% end %>
               </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:bg-white/15 transition-all group relative overflow-hidden">
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-500/20 rounded-full blur-2xl group-hover:bg-blue-500/30 transition-all"></div>

      <div class="relative z-10">
        <div class="w-12 h-12 bg-blue-500/20 rounded-2xl flex items-center justify-center mb-6 border border-blue-400/30 text-blue-200">
          <%= lucide_icon('sliders', class: "w-6 h-6") %>
        </div>
        <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Customize Games</h2>
        <p class="text-blue-200 mb-6 text-sm leading-relaxed">Personalize your games with custom content. Create prompt packs, trivia questions, and more.</p>
        <%= link_to customize_path, class: "inline-flex items-center gap-2 font-bold text-blue-300 hover:text-white transition-colors" do %>
          Customize <%= lucide_icon('arrow-right', class: "w-4 h-4") %>
        <% end %>
      </div>
    </div>

    <div class="bg-gradient-to-br from-orange-500/20 to-amber-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-orange-500/30 hover:to-amber-600/30 transition-all group relative overflow-hidden">
       <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-500/20 rounded-full blur-2xl group-hover:bg-orange-500/30 transition-all"></div>

       <div class="relative z-10">
        <div class="w-12 h-12 bg-orange-500/20 rounded-2xl flex items-center justify-center mb-6 border border-orange-400/30 text-orange-200">
          <span class="text-2xl">🏆</span>
        </div>
        <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Host a Game</h2>
        <p class="text-orange-100/80 mb-6 text-sm leading-relaxed">Start a new game room. Launch a Big Screen session for players to join.</p>
        <%= link_to root_path, class: "block w-full text-center bg-orange-500 hover:bg-orange-400 text-white font-black py-4 rounded-xl shadow-lg shadow-orange-500/30 transition-all tracking-tight text-sm" do %>
          Start Hosting
        <% end %>
      </div>
    </div>
  </main>

  <section class="max-w-5xl mx-auto mb-12">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-xl font-bold text-white tracking-wide">My Games</h3>
      <div class="flex items-center gap-4">
        <% if @game_templates.any? %>
          <%= link_to "View All", game_templates_path, class: "text-xs font-bold text-blue-300 hover:text-white transition-colors tracking-widest" %>
        <% end %>
        <%= link_to new_game_template_path, class: "inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white font-bold text-xs py-2 px-4 rounded-lg shadow-lg shadow-orange-500/30 transition-all" do %>
          <%= lucide_icon('plus', class: "w-3 h-3") %>
          Create Game
        <% end %>
      </div>
    </div>
    <% if @game_templates.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @game_templates.each do |template| %>
          <%= render "game_templates/template_card", template: template %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 text-center">
        <p class="text-blue-200/70 text-sm mb-4">Save game configurations to launch with one click.</p>
        <%= link_to new_game_template_path, class: "inline-flex items-center gap-2 text-blue-300 hover:text-white font-bold transition-colors text-sm" do %>
          Create your first game <%= lucide_icon('arrow-right', class: "w-4 h-4") %>
        <% end %>
      </div>
    <% end %>
  </section>

  <% if @recent_packs.any? %>
    <section class="max-w-5xl mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-white tracking-wide">Recent Prompt Packs</h3>
        <%= link_to "View All", prompt_packs_path, class: "text-xs font-bold text-blue-300 hover:text-white transition-colors tracking-widest" %>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% @recent_packs.each do |pack| %>
          <%= link_to edit_prompt_pack_path(pack), class: "bg-white/5 backdrop-blur-sm p-5 rounded-2xl border border-white/10 flex items-center gap-4 hover:bg-white/10 hover:border-white/20 transition-all cursor-pointer group" do %>
            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-blue-200 group-hover:text-white transition-colors">
              <%= lucide_icon('folder', class: "w-5 h-5") %>
            </div>
            <div>
              <h4 class="font-bold text-white group-hover:text-blue-200 transition-colors"><%= pack.name %></h4>
              <p class="text-[10px] font-bold text-blue-400 bg-blue-900/30 px-2 py-0.5 rounded-md inline-block border border-blue-500/20 mt-1">
                <%= pack.prompts.count %> prompts
              </p>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
