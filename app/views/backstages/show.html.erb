<div class="container mx-auto p-4 text-white" data-controller="reconnect">
  <%= turbo_stream_from @room %>

  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6 gap-2">
    <h1 class="text-xl sm:text-3xl font-black tracking-tighter drop-shadow-md">Backstage: <span class="text-blue-200"><%= @room.code %></span></h1>
    <div class="flex items-center gap-2 sm:gap-4 flex-wrap">
      <%= link_to room_stage_path(@room.code), target: "_blank", class: "hidden sm:flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition font-bold shadow-lg border border-white/20" do %>
        <%= lucide_icon('external-link', class: "w-4 h-4") %>
        Launch Stage View
      <% end %>
      <span class="px-3 py-1 bg-white/10 backdrop-blur-md rounded-full text-sm font-bold tracking-wider text-blue-200 border border-white/10 whitespace-nowrap">
        Status: <%= @room.status.titleize %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Host Controls -->
    <div id="backstage-host-controls" class="bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 shadow-xl">
      <h2 class="text-xl font-bold mb-4 text-white tracking-wide border-b border-white/10 pb-2">Host Controls</h2>

      <%= render "rooms/host_controls", room: @room, backstage: true %>
    </div>

    <!-- Player List -->
    <div class="bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 shadow-xl">
      <div class="flex justify-between items-center mb-4 border-b border-white/10 pb-2">
        <h2 class="text-xl font-bold text-white tracking-wide">Players</h2>
        <span id="player-count" class="text-sm font-bold text-blue-200 tracking-wider"><%= @room.players.active_players.count %> connected</span>
      </div>
      <ul id="backstage-player-list" class="space-y-2">
        <% @room.players.active_players.each do |player| %>
          <%= render "players/backstage_player", player: player %>
        <% end %>
        <% if @room.players.active_players.empty? %>
          <li id="no-players-placeholder" class="text-blue-300/50 text-center py-4 italic font-medium">No players yet.</li>
        <% end %>
      </ul>
    </div>
  </div>

  <% if @room.current_game.is_a?(ScavengerHuntGame) && @room.current_game.accepts_submissions? %>
    <div class="mt-8 bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 shadow-xl">
      <h2 class="text-xl font-bold mb-4 text-white tracking-wide border-b border-white/10 pb-2">Submission Curation</h2>
      <%= render "games/scavenger_hunt/curation_panel", game: @room.current_game, room: @room %>
    </div>
  <% end %>

  <!-- Waiting Room Section (always rendered so Turbo Stream appends have a target) -->
  <% pending_players = @room.players.pending_approval %>
  <div class="mt-8 bg-orange-500/10 backdrop-blur-md rounded-3xl p-6 border-2 border-orange-400/50 shadow-xl">
    <div class="flex justify-between items-center mb-4 border-b border-orange-400/30 pb-2">
      <h2 class="text-xl font-bold text-white tracking-wide">Waiting Room</h2>
      <span class="text-sm font-bold text-orange-200 tracking-wider">
        <%= pending_players.count %> pending
      </span>
    </div>
    <ul id="waiting-room-list" class="space-y-2">
      <% pending_players.each do |player| %>
        <%= render "players/waiting_player", player: player %>
      <% end %>
    </ul>
  </div>

  <% if @room.stage_only? %>
    <!-- Score Tracker -->
    <div class="mt-8">
      <h2 class="text-xl font-bold mb-4 text-white tracking-wide">Score Tracker</h2>
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 shadow-xl">
        <div id="score-tracker">
          <%= render "score_tracker_entries/tracker", room: @room %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Moderation Stream -->
  <% if @room.current_game&.class&.supports_response_moderation? %>
    <div class="mt-8">
      <h2 class="text-xl font-bold mb-4 text-white tracking-wide">Moderation Queue</h2>
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 shadow-xl">
        <div id="moderation-queue" class="space-y-4">
          <% if @moderation_queue.any? %>
            <% @moderation_queue.each do |item| %>
              <% if item.is_a?(CategoryAnswer) %>
                <%= render "category_answers/backstage_answer", answer: item, room: @room %>
              <% else %>
                <%= render "responses/backstage_response", response: item %>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-blue-300/50 text-center italic font-medium">No active responses to moderate.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
  <div class="mt-8 bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 text-center">
    <p class="text-blue-200 font-medium mb-3">Help us improve RoomRally</p>
    <%= link_to "https://forms.gle/DvBEVC5DwqcGAnHv8", target: "_blank", rel: "noopener noreferrer",
          class: "inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-blue-200 font-bold rounded-full border border-white/20 transition" do %>
      Share feedback &rarr;
    <% end %>
  </div>

  <%= turbo_frame_tag "modal" %>
</div>
