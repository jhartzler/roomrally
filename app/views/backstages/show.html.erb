<div class="container mx-auto p-4">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Backstage: <%= @room.code %></h1>
    <span class="px-3 py-1 bg-gray-100 rounded-full text-sm font-medium text-gray-600">
      Status: <%= @room.status.titleize %>
    </span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Host Controls -->
    <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
      <h2 class="text-xl font-bold mb-4 text-gray-800">Host Controls</h2>
      
      <% if @room.status == "lobby" %>
        <% if @room.enough_players? %>
          <%= form_with url: start_game_room_path(@room.code), method: :post, local: true, class: "space-y-4" do |f| %>
            <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
              <h3 class="font-bold text-gray-700 mb-2">Game Settings</h3>
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <label class="flex items-center gap-2 cursor-pointer">
                  <%= check_box_tag :timer_enabled, "1", false, class: "form-checkbox h-5 w-5 text-indigo-600 rounded focus:ring-indigo-500" %>
                  <span class="text-gray-700 font-medium">Enable Timer</span>
                </label>
        
                <label class="flex items-center gap-2">
                   <span class="text-gray-700 font-medium text-sm">Seconds per round:</span>
                   <%= number_field_tag :timer_increment, 60, min: 10, max: 300, class: "w-20 form-input rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
                </label>
              </div>
            </div>
            <%= f.submit "Start Game", class: "w-full bg-indigo-600 text-white font-bold py-3 px-6 rounded-xl hover:bg-indigo-700 transition duration-200 shadow-lg cursor-pointer" %>
          <% end %>
        <% else %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-center">
            <p class="text-yellow-700 font-medium">Waiting for players (<%= @room.players.count %>/3)...</p>
            <p class="text-yellow-600 text-sm mt-1">Need at least 3 players to start.</p>
          </div>
        <% end %>
      <% else %>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
          <p class="text-green-700 font-bold text-lg">Game in Progress</p>
        </div>
      <% end %>
    </div>

    <!-- Player List -->
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-gray-800">Players</h2>
        <span class="text-sm font-medium text-gray-500"><%= @room.players.count %> connected</span>
      </div>
      <ul class="space-y-2">
        <% @room.players.each do |player| %>
          <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <span class="font-medium text-gray-700"><%= player.name %></span>
            <% if player == @room.host %>
              <span class="text-xs font-bold px-2 py-1 bg-yellow-100 text-yellow-800 rounded uppercase">Host</span>
            <% end %>
          </li>
        <% end %>
        <% if @room.players.empty? %>
          <li class="text-gray-400 text-center py-4 italic">No players yet.</li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- Moderation Stream -->
  <div class="mt-8">
    <h2 class="text-xl font-bold mb-4 text-gray-800">Moderation Queue</h2>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <% if @room.current_game.present? && @room.current_game.respond_to?(:responses) %>
         <% responses = Response.joins(:prompt_instance).where(prompt_instances: { write_and_vote_game_id: @room.current_game.id, round: @room.current_game.round }).where(status: "submitted") %>
         <% if responses.any? %>
           <div class="space-y-4">
             <% responses.each do |response| %>
               <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-100">
                 <div>
                   <p class="font-medium text-gray-900"><%= response.body || "Writing..." %></p>
                   <p class="text-sm text-gray-500 mt-1">Prompt: <%= response.prompt_instance.body %></p>
                   <p class="text-xs text-gray-400 mt-1">by <%= response.player.name %></p>
                 </div>
                 <div class="flex gap-2">
                   <%= button_to "Reject", response_rejections_path(response), method: :post, class: "px-3 py-1 bg-red-100 text-red-700 rounded hover:bg-red-200 text-sm font-medium" %>
                 </div>
               </div>
             <% end %>
           </div>
         <% else %>
           <p class="text-gray-400 text-center italic">No active responses to moderate.</p>
         <% end %>
      <% else %>
         <p class="text-gray-400 text-center italic">Game not started or no moderation available.</p>
      <% end %>
    </div>
  </div>
</div>
