<div class="p-4 md:p-8 text-white">
  <header class="max-w-5xl mx-auto mb-10">
    <h1 class="text-4xl font-black text-white drop-shadow-lg mb-2">
      Game Customization
    </h1>
    <p class="text-blue-200 font-bold tracking-widest text-sm">Choose a game to customize with your own content</p>
  </header>

  <main class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Write And Vote Game Card -->
      <div class="bg-gradient-to-br from-blue-500/20 to-purple-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-blue-500/30 hover:to-purple-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-blue-500/20 rounded-full blur-3xl group-hover:bg-blue-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-blue-500/20 rounded-2xl flex items-center justify-center mb-6 border border-blue-400/30">
            <span class="text-4xl">✍️</span>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Comedy Clash</h2>
            <p class="text-blue-200 text-sm font-medium uppercase tracking-widest mb-4">Write And Vote</p>
            <p class="text-blue-100/80 text-sm leading-relaxed mb-6">
              Players write creative responses to prompts, then vote on their favorites. Customize with your own prompt packs.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <span class="text-2xl">📚</span>
              <div>
                <p class="text-xs font-bold text-blue-300 uppercase tracking-widest">Prompt Packs</p>
                <p class="text-lg font-black text-white"><%= @prompt_packs_count %> custom <%= 'pack'.pluralize(@prompt_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= link_to prompt_packs_path, class: "block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-xl shadow-lg shadow-blue-900/20 transition-all transform hover:scale-[1.02] active:scale-95" do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Prompts</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Speed Trivia Game Card -->
      <div class="bg-gradient-to-br from-purple-500/20 to-pink-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-purple-500/30 hover:to-pink-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-purple-500/20 rounded-full blur-3xl group-hover:bg-purple-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-purple-500/20 rounded-2xl flex items-center justify-center mb-6 border border-purple-400/30">
            <%= lucide_icon('brain', class: "w-10 h-10 text-purple-200") %>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Think Fast</h2>
            <p class="text-purple-200 text-sm font-medium uppercase tracking-widest mb-4">Speed Trivia</p>
            <p class="text-purple-100/80 text-sm leading-relaxed mb-6">
              Fast-paced trivia where players race to answer multiple-choice questions. Create custom trivia packs for any topic.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <%= lucide_icon('brain', class: "w-8 h-8 text-purple-300") %>
              <div>
                <p class="text-xs font-bold text-purple-300 uppercase tracking-widest">Trivia Packs</p>
                <p class="text-lg font-black text-white"><%= @trivia_packs_count %> custom <%= 'pack'.pluralize(@trivia_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= link_to trivia_packs_path, class: "block w-full text-center bg-purple-600 hover:bg-purple-700 text-white font-black py-4 rounded-xl shadow-lg shadow-purple-900/20 transition-all transform hover:scale-[1.02] active:scale-95" do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Trivia</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Category List Game Card -->
      <div class="bg-gradient-to-br from-green-500/20 to-teal-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-green-500/30 hover:to-teal-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-green-500/20 rounded-full blur-3xl group-hover:bg-green-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-green-500/20 rounded-2xl flex items-center justify-center mb-6 border border-green-400/30">
            <span class="text-4xl">📋</span>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">A-List</h2>
            <p class="text-green-200 text-sm font-medium uppercase tracking-widest mb-4">Category List</p>
            <p class="text-green-100/80 text-sm leading-relaxed mb-6">
              Players race to name things that fit a category. Create custom category packs for any theme or topic.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <span class="text-2xl">📋</span>
              <div>
                <p class="text-xs font-bold text-green-300 uppercase tracking-widest">Category Packs</p>
                <p class="text-lg font-black text-white"><%= @category_packs_count %> custom <%= 'pack'.pluralize(@category_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= link_to category_packs_path, class: "block w-full text-center bg-green-600 hover:bg-green-700 text-white font-black py-4 rounded-xl shadow-lg shadow-green-900/20 transition-all transform hover:scale-[1.02] active:scale-95" do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Categories</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Scavenger Hunt Game Card -->
      <div class="bg-gradient-to-br from-amber-500/20 to-orange-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-amber-500/30 hover:to-orange-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-amber-500/20 rounded-full blur-3xl group-hover:bg-amber-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-amber-500/20 rounded-2xl flex items-center justify-center mb-6 border border-amber-400/30">
            <span class="text-4xl">📸</span>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Photo Scavenger Hunt</h2>
            <p class="text-amber-200 text-sm font-medium uppercase tracking-widest mb-4">Scavenger Hunt</p>
            <p class="text-amber-100/80 text-sm leading-relaxed mb-6">
              Teams race to snap photos matching creative prompts. Create custom hunt packs for any event or theme.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <span class="text-2xl">📸</span>
              <div>
                <p class="text-xs font-bold text-amber-300 uppercase tracking-widest">Hunt Packs</p>
                <p class="text-lg font-black text-white"><%= @hunt_packs_count %> custom <%= 'pack'.pluralize(@hunt_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= link_to hunt_packs_path, class: "block w-full text-center bg-amber-600 hover:bg-amber-700 text-white font-black py-4 rounded-xl shadow-lg shadow-amber-900/20 transition-all transform hover:scale-[1.02] active:scale-95" do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Hunt Packs</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Info Box -->
    <div class="mt-12 bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 bg-blue-500/20 rounded-full flex items-center justify-center border border-blue-400/30">
          <%= lucide_icon('info', class: "w-5 h-5 text-blue-300") %>
        </div>
        <div>
          <h3 class="font-bold text-white mb-2">What are content packs?</h3>
          <p class="text-blue-200/80 text-sm leading-relaxed">
            Content packs let you customize games with your own questions and prompts. Create themed packs for specific occasions,
            inside jokes with friends, or educational content. Each pack can be selected when starting a new game room.
          </p>
        </div>
      </div>
    </div>
  </main>
</div>
