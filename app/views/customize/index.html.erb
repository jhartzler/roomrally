<div class="min-h-screen p-6 md:p-12 font-sans text-white">
  <header class="max-w-5xl mx-auto mb-10">
    <%= link_to dashboard_path, class: "group flex items-center gap-2 text-primary-200 hover:text-white transition-colors font-bold mb-6 w-fit" do %>
      <div class="p-2 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors border border-white/10">
        <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
      </div>
      <span>Back to Dashboard</span>
    <% end %>

    <h1 class="text-4xl font-black text-white drop-shadow-lg mb-2">
      Game Customization
    </h1>
    <p class="text-primary-200 font-bold tracking-widest text-sm">Choose a game to customize with your own content</p>
  </header>

  <main class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Write And Vote Game Card -->
      <div class="bg-gradient-to-br from-primary-500/20 to-secondary-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-primary-500/30 hover:to-secondary-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-primary-500/20 rounded-full blur-3xl group-hover:bg-primary-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-primary-500/20 rounded-2xl flex items-center justify-center mb-6 border border-primary-400/30">
            <span class="text-4xl">✍️</span>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Comedy Clash</h2>
            <p class="text-primary-200 text-sm font-medium uppercase tracking-widest mb-4">Write And Vote</p>
            <p class="text-primary-100/80 text-sm leading-relaxed mb-6">
              Players write creative responses to prompts, then vote on their favorites. Customize with your own prompt packs.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <span class="text-2xl">📚</span>
              <div>
                <p class="text-xs font-bold text-primary-300 uppercase tracking-widest">Prompt Packs</p>
                <p class="text-lg font-black text-white"><%= @prompt_packs_count %> custom <%= 'pack'.pluralize(@prompt_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= ui_button link_to(prompt_packs_path) do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Prompts</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Speed Trivia Game Card -->
      <div class="bg-gradient-to-br from-secondary-500/20 to-accent-600/20 backdrop-blur-md rounded-3xl p-8 border border-white/20 hover:from-secondary-500/30 hover:to-accent-600/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-secondary-500/20 rounded-full blur-3xl group-hover:bg-secondary-500/30 transition-all"></div>

        <div class="relative z-10">
          <!-- Game Icon -->
          <div class="w-16 h-16 bg-secondary-500/20 rounded-2xl flex items-center justify-center mb-6 border border-secondary-400/30">
            <%= lucide_icon('brain', class: "w-10 h-10 text-secondary-200") %>
          </div>

          <!-- Game Info -->
          <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Think Fast</h2>
            <p class="text-secondary-200 text-sm font-medium uppercase tracking-widest mb-4">Speed Trivia</p>
            <p class="text-secondary-100/80 text-sm leading-relaxed mb-6">
              Fast-paced trivia where players race to answer multiple-choice questions. Create custom trivia packs for any topic.
            </p>

            <!-- Content Type Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20">
              <%= lucide_icon('brain', class: "w-8 h-8 text-secondary-300") %>
              <div>
                <p class="text-xs font-bold text-secondary-300 uppercase tracking-widest">Trivia Packs</p>
                <p class="text-lg font-black text-white"><%= @trivia_packs_count %> custom <%= 'pack'.pluralize(@trivia_packs_count) %></p>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <%= ui_button link_to(trivia_packs_path), variant: :secondary do %>
            <div class="flex items-center justify-center gap-2">
              <span>Manage Trivia</span>
              <%= lucide_icon('arrow-right', class: "w-5 h-5") %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Info Box -->
    <div class="mt-12 bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 bg-primary-500/20 rounded-full flex items-center justify-center border border-primary-400/30">
          <%= lucide_icon('info', class: "w-5 h-5 text-primary-300") %>
        </div>
        <div>
          <h3 class="font-bold text-white mb-2">What are content packs?</h3>
          <p class="text-primary-200/80 text-sm leading-relaxed">
            Content packs let you customize games with your own questions and prompts. Create themed packs for specific occasions,
            inside jokes with friends, or educational content. Each pack can be selected when starting a new game room.
          </p>
        </div>
      </div>
    </div>
  </main>
</div>
