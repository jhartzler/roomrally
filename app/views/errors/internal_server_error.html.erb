<% content_for :title, "Server Error | RoomRally" %>

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center text-white">
  <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 shadow-2xl border border-white/20 max-w-lg w-full">
    <h1 class="text-8xl font-black mb-4 text-transparent bg-clip-text bg-gradient-to-tr from-red-400 to-rose-600 drop-shadow-sm">500</h1>
    <h2 class="text-3xl font-bold mb-6">Something Went Wrong</h2>
    <p class="text-lg text-blue-100 mb-8 leading-relaxed">
      Our servers are having a bit of a glitch. We've been notified and are working on fixing it.
    </p>
    
    <%= link_to root_path, class: "inline-block px-8 py-4 bg-white/20 hover:bg-white/30 text-white font-bold rounded-xl shadow-lg backdrop-blur-sm transition-all duration-200" do %>
      Return to Lobby
    <% end %>
  </div>
</div>
