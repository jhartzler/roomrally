<% content_for(:hide_footer, true) %>
<%= turbo_stream_from @room %>
<%= turbo_stream_from @player %>

<div class="min-h-screen p-4" data-controller="reconnect">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-8 mt-8">
      <div class="inline-block bg-white/20 backdrop-blur-sm rounded-2xl px-8 py-4 mb-4">
        <p class="text-white text-sm font-semibold mb-1">Room Code</p>
        <p class="text-4xl font-black text-white font-mono"><%= @room.code %></p>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-6 py-3">
          <p class="text-white font-semibold">👤 You: <span class="font-black"><%= @player.name %></span></p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-6 py-3">
          <p class="text-white font-semibold flex items-center gap-2">🏆 <span class="font-black"><%= @room.display_name %></span></p>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <turbo-frame id="hand_screen" class="w-full">
      <%= render "rooms/hand_screen_content", room: @room, player: @player %>
    </turbo-frame>
  </div>
</div>
