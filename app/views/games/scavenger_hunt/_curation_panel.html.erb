<%# app/views/games/scavenger_hunt/_curation_panel.html.erb %>
<%# locals: (game:, room:) %>
<div class="space-y-4" data-controller="games--image-viewer">
  <% game.hunt_prompt_instances.includes(hunt_submissions: [:player, { media_attachment: :blob }]).each do |instance| %>
    <% next if instance.hunt_submissions.empty? %>
    <div id="curation-prompt-<%= instance.id %>">
      <h3 class="text-white font-bold text-sm mb-2"><%= instance.body %> <span class="text-white/40 text-xs">(<%= instance.weight %> pts)</span></h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% instance.hunt_submissions.each do |sub| %>
          <div id="curation-submission-<%= sub.id %>" class="bg-white/10 rounded-xl p-2 border border-white/10 <%= 'border-amber-500/50' if sub.late? %>">
            <% if sub.media.attached? %>
              <% media_url = url_for(sub.media) %>
              <button type="button"
                      class="w-full cursor-pointer"
                      data-action="click->games--image-viewer#open"
                      data-games--image-viewer-src-param="<%= media_url %>"
                      data-games--image-viewer-caption-param="<%= sub.player.team_name.presence || sub.player.name %> — <%= instance.body %>">
                <%= image_tag media_url, class: "w-full h-24 object-cover rounded-lg", alt: "" %>
              </button>
            <% end %>
            <div class="flex items-center justify-between mt-1">
              <div>
                <p class="text-white font-bold text-xs"><%= sub.player.team_name.presence || sub.player.name %></p>
                <% if sub.late? %>
                  <span class="text-amber-400 text-[10px] font-bold">LATE</span>
                <% end %>
              </div>
              <div class="flex gap-1">
                <%= button_to scavenger_hunt_game_completion_path(game, sub),
                      method: :patch,
                      params: { action_type: "complete", value: (!sub.completed?).to_s, code: room.code },
                      class: "w-7 h-7 rounded flex items-center justify-center text-xs font-bold #{sub.completed? ? 'bg-green-600 text-white' : 'bg-white/20 text-white/60'}" do %>
                  &#10003;
                <% end %>
                <%= button_to scavenger_hunt_game_completion_path(game, sub),
                      method: :patch,
                      params: { action_type: "favorite", value: (!sub.favorite?).to_s, code: room.code },
                      class: "w-7 h-7 rounded flex items-center justify-center text-xs font-bold #{sub.favorite? ? 'bg-yellow-600 text-white' : 'bg-white/20 text-white/60'}" do %>
                  &#9733;
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Lightbox overlay %>
  <div data-games--image-viewer-target="overlay"
       class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center"
       data-action="click->games--image-viewer#close keydown.escape@window->games--image-viewer#close keydown.left@window->games--image-viewer#prev keydown.right@window->games--image-viewer#next">
    <button type="button" data-action="click->games--image-viewer#close" class="absolute top-4 right-4 text-white/80 hover:text-white text-3xl font-bold z-10">&times;</button>
    <button type="button" data-action="click->games--image-viewer#prev" class="absolute left-4 text-white/80 hover:text-white text-4xl font-bold z-10">&lsaquo;</button>
    <button type="button" data-action="click->games--image-viewer#next" class="absolute right-4 text-white/80 hover:text-white text-4xl font-bold z-10">&rsaquo;</button>
    <div class="flex flex-col items-center max-w-[90vw] max-h-[90vh]" data-action="click->games--image-viewer#stopPropagation">
      <img data-games--image-viewer-target="image" class="max-w-full max-h-[80vh] object-contain rounded-xl" src="" alt="">
      <p data-games--image-viewer-target="caption" class="text-white font-bold mt-3 text-center"></p>
    </div>
  </div>
</div>
