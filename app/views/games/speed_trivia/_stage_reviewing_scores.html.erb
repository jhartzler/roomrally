<%# app/views/games/speed_trivia/_stage_reviewing_scores.html.erb %>
<div id="stage_reviewing_scores" class="flex flex-col items-center justify-center flex-1 animate-fade-in">
  <div class="mb-[3vh]">
    <span class="text-vh-2xl text-blue-200 font-bold uppercase tracking-widest">
      Scores after Question <%= game.current_question_index + 1 %>
    </span>
  </div>

  <%= render "games/speed_trivia/score_podium",
        game: game,
        room: room,
        previous_top_player_ids: local_assigns[:previous_top_player_ids] || [] %>
</div>
