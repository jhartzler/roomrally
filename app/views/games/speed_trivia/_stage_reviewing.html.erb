<div id="stage_reviewing" class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
  <% current_question = game.current_question %>

  <!-- Question Counter -->
  <div class="mb-8">
    <span class="text-2xl text-blue-200 font-bold uppercase tracking-widest">
      Question <%= game.current_question_index + 1 %> Results
    </span>
  </div>

  <!-- Question with Answer -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-12 shadow-2xl text-center max-w-6xl w-full mb-8">
    <p class="text-2xl text-blue-200 mb-4"><%= current_question&.body %></p>
    <div class="flex flex-wrap items-center justify-center gap-6">
      <% current_question&.correct_answers&.each do |answer| %>
        <div class="flex items-center gap-2">
          <span class="text-4xl">✓</span>
          <h2 class="text-5xl md:text-7xl font-black text-green-400"><%= answer %></h2>
        </div>
      <% end %>
    </div>
  </div>

  <%= render "games/speed_trivia/vote_summary", question: current_question %>
</div>
