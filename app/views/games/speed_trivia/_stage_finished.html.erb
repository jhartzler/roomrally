<div id="stage_finished" class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
  <div class="bg-white/10 backdrop-blur-xl border-2 border-yellow-400/30 rounded-3xl p-16 text-center max-w-5xl w-full relative overflow-hidden shadow-2xl">
    <div class="absolute inset-0 bg-[url('confetti.svg')] opacity-20"></div>

    <h2 class="text-8xl font-black text-transparent bg-clip-text bg-gradient-to-tr from-yellow-300 via-yellow-100 to-yellow-500 mb-4 drop-shadow-xl">
      Game Over!
    </h2>
    <p class="text-2xl text-blue-200 mb-12">Final Standings</p>

    <%= render "games/speed_trivia/score_podium",
          game: game,
          room: room,
          previous_top_player_ids: local_assigns[:previous_top_player_ids] || [] %>

    <div class="mt-16">
      <p class="text-2xl text-gray-400">Host can start a new game anytime.</p>
    </div>
  </div>
</div>
