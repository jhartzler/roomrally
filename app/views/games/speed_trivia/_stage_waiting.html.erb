<div id="stage_waiting" class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-16 shadow-2xl text-center max-w-4xl">
    <div class="text-9xl mb-8 animate-bounce">🧠</div>
    <h2 class="text-5xl font-black text-white mb-8">Get Ready!</h2>
    <p class="text-3xl text-blue-200 font-medium mb-8">
      <%= game.trivia_question_instances.count %> questions ahead
    </p>
    <p class="text-xl text-blue-300">
      Answer fast for more points!
    </p>
  </div>
</div>
