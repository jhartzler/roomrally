<%# Preload all question images so they display instantly when questions appear %>
<% game.trivia_question_instances.each do |q| %>
  <% if q.image.attached? %>
    <link rel="preload" as="image" href="<%= rails_blob_path(q.image.blob) %>">
  <% end %>
<% end %>

<div id="stage_waiting" class="flex flex-col items-center justify-center flex-1 animate-fade-in">
  <div class="bg-theme-surface backdrop-blur-xl border border-theme-surface-border rounded-3xl p-[4vh] shadow-2xl text-center max-w-4xl">
    <div class="text-[8vh] mb-[2vh] animate-bounce">🧠</div>
    <h2 class="text-vh-4xl font-black text-white mb-[2vh]">Get Ready!</h2>
    <p class="text-vh-2xl text-theme-secondary font-medium mb-[2vh]">
      <%= game.trivia_question_instances.count %> questions ahead
    </p>
    <p class="text-vh-lg text-theme-secondary">
      Answer fast for more points!
    </p>
  </div>
</div>
