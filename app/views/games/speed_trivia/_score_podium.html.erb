<%# app/views/games/speed_trivia/_score_podium.html.erb %>
<%# Renders top-4 animated score podium with slot-based bonk animations %>
<%# Locals: game, room, previous_top_player_ids (optional) %>

<% top_players = room.players.active_players.order(score: :desc).limit(4) %>
<% previous_ids = local_assigns[:previous_top_player_ids] || [] %>
<% current_ids = top_players.map(&:id) %>
<% current_set = current_ids.to_set %>

<%# Build a lookup for previous occupants by position %>
<% prev_players_by_id = previous_ids.any? ? Player.where(id: previous_ids - current_ids).index_by(&:id) : {} %>

<div class="bg-theme-surface backdrop-blur-md border border-theme-surface-border rounded-2xl p-[2vh] max-w-4xl w-full"
     data-controller="games--podium"
     data-games--podium-players-value="<%= current_ids.to_json %>"
     data-games--podium-previous-value="<%= previous_ids.to_json %>">

  <div class="space-y-[2vh]">
    <% top_players.each_with_index do |player, index| %>
      <% is_entering = !previous_ids.include?(player.id) && previous_ids.any? %>
      <% prev_occupant_id = previous_ids[index] %>
      <% prev_was_bonked = prev_occupant_id && !current_set.include?(prev_occupant_id) %>
      <% prev_player = prev_was_bonked ? prev_players_by_id[prev_occupant_id] : nil %>

      <div class="relative overflow-visible" data-podium-slot="<%= index %>">
        <% if is_entering && prev_player %>
          <%# Ghost: old occupant overlaid in front, will be bonked off %>
          <div class="flex items-center bg-black/40 rounded-xl p-[2vh] border border-theme-surface-border absolute inset-0 z-[2]"
               data-podium-role="ghost">
            <div class="text-vh-3xl w-[8vh] font-bold text-theme-text-muted">#<%= index + 1 %></div>
            <div class="text-vh-3xl font-bold text-white flex-grow text-left mx-[2vh]"><%= prev_player.name %></div>
            <div class="text-vh-4xl font-black text-theme-accent font-mono"><%= prev_player.score %></div>
          </div>

          <%# Entering player rises from behind %>
          <div class="flex items-center bg-black/40 rounded-xl p-[2vh] border border-theme-surface-border relative z-[1]
                      <%= index == 0 ? 'border-2 border-theme-accent-subtle shadow-[0_0_30px_rgba(234,179,8,0.3)]' : '' %>"
               data-podium-role="entering">
            <div class="text-vh-3xl w-[8vh] font-bold text-theme-text-muted">#<%= index + 1 %></div>
            <div class="text-vh-3xl font-bold text-white flex-grow text-left mx-[2vh]"><%= player.name %></div>
            <div class="text-vh-4xl font-black text-theme-accent font-mono"><%= player.score %></div>
          </div>
        <% else %>
          <div class="flex items-center bg-black/40 rounded-xl p-[2vh] border border-theme-surface-border
                      <%= index == 0 ? 'border-2 border-theme-accent-subtle shadow-[0_0_30px_rgba(234,179,8,0.3)]' : '' %>"
               data-podium-role="card">
            <div class="text-vh-3xl w-[8vh] font-bold text-theme-text-muted">#<%= index + 1 %></div>
            <div class="text-vh-3xl font-bold text-white flex-grow text-left mx-[2vh]"><%= player.name %></div>
            <div class="text-vh-4xl font-black text-theme-accent font-mono"><%= player.score %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
