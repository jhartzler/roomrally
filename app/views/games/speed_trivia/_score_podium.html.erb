<%# app/views/games/speed_trivia/_score_podium.html.erb %>
<%# Renders top-4 animated score podium %>
<%# Locals: game, room, previous_top_player_ids (optional) %>

<% top_players = room.players.active_players.order(score: :desc).limit(4) %>
<% previous_ids = local_assigns[:previous_top_player_ids] || [] %>
<% current_ids = top_players.map(&:id) %>

<%# Also include exiting players that were in previous top-4 but aren't anymore %>
<% exiting_ids = previous_ids - current_ids %>
<% exiting_players = exiting_ids.any? ? Player.where(id: exiting_ids) : [] %>

<div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-8 max-w-4xl w-full"
     data-controller="games--podium"
     data-games--podium-players-value="<%= current_ids.to_json %>"
     data-games--podium-previous-value="<%= previous_ids.to_json %>">

  <div class="space-y-4 overflow-visible">
    <%# Render exiting players (will be animated out) %>
    <% exiting_players.each do |player| %>
      <div class="flex items-center bg-black/40 rounded-xl p-6 border border-white/10"
           data-podium-player-id="<%= player.id %>">
        <div class="text-4xl w-16 font-bold text-gray-500">--</div>
        <div class="text-4xl font-bold text-white/50 flex-grow text-left mx-8"><%= player.name %></div>
        <div class="text-5xl font-black text-yellow-400/50 font-mono"><%= player.score %></div>
      </div>
    <% end %>

    <%# Render current top-4 %>
    <% top_players.each_with_index do |player, index| %>
      <div class="flex items-center bg-black/40 rounded-xl p-6 border border-white/10
                  <%= index == 0 ? 'border-2 border-yellow-400/50 shadow-[0_0_30px_rgba(234,179,8,0.3)]' : '' %>"
           data-podium-player-id="<%= player.id %>">
        <div class="text-4xl w-16 font-bold text-gray-400">#<%= index + 1 %></div>
        <div class="text-4xl font-bold text-white flex-grow text-left mx-8"><%= player.name %></div>
        <div class="text-5xl font-black text-yellow-400 font-mono"><%= player.score %></div>
      </div>
    <% end %>
  </div>
</div>
