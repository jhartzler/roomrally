<%# Preload all question images so they display instantly when questions appear %>
<% game.trivia_question_instances.each do |q| %>
  <% if q.image.attached? %>
    <link rel="preload" as="image" href="<%= rails_blob_path(q.image.blob) %>">
  <% end %>
<% end %>

<div id="stage_instructions" class="flex flex-col items-center justify-center flex-1 animate-fade-in">
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-[4vh] shadow-2xl text-center max-w-4xl">
    <div class="text-[8vh] mb-[2vh]">🧠</div>
    <h2 class="text-vh-4xl font-black text-white mb-[3vh]">How to Play</h2>

    <div class="space-y-[2vh] text-left max-w-2xl mx-auto mb-[4vh]">
      <div class="flex items-start gap-[1vh]">
        <span class="text-vh-3xl">⚡</span>
        <p class="text-vh-xl text-blue-200">Answer trivia questions as fast as you can</p>
      </div>
      <div class="flex items-start gap-[1vh]">
        <span class="text-vh-3xl">🏆</span>
        <p class="text-vh-xl text-blue-200">Faster correct answers earn more points</p>
      </div>
      <div class="flex items-start gap-[1vh]">
        <span class="text-vh-3xl">📱</span>
        <p class="text-vh-xl text-blue-200">Use your phone to select answers</p>
      </div>
    </div>

    <p class="text-vh-lg text-blue-300 animate-pulse">
      Waiting for host to start...
    </p>
  </div>
</div>
