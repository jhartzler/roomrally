<div id="stage_reviewing" class="flex flex-col items-center justify-center flex-1 animate-fade-in">
  <div class="mb-[2vh]">
    <span class="text-vh-2xl text-theme-secondary font-bold uppercase tracking-widest">
      Round <%= game.current_round %> &mdash; Letter "<%= game.current_letter %>"
    </span>
  </div>

  <% categories = game.current_round_categories.to_a %>
  <% position = game.reviewing_category_position %>
  <% ci = categories[position] %>

  <p class="text-theme-secondary text-vh-sm font-medium mb-[1vh]">
    Category <%= position + 1 %> of <%= categories.size %>
  </p>

  <% if ci %>
    <div class="w-full max-w-4xl px-[2vh] mb-[3vh] max-h-[60vh] overflow-y-auto">
      <div class="bg-theme-surface backdrop-blur-md border border-theme-surface-border rounded-2xl p-[2vh]">
        <h3 class="text-vh-xl font-bold text-theme-accent mb-[2vh]"><%= ci.name %></h3>
        <div class="space-y-[1vh]">
          <% answers = ci.answers_with_duplicate_detection(exclude_hidden: true) %>
          <% answers.each do |answer| %>
            <div class="flex items-center justify-between bg-black/30 rounded-xl px-[2vh] py-[1vh]
              <%= answer.effectively_struck? ? 'border border-white/5 opacity-50' : 'border border-theme-surface-border' %>">
              <div class="flex items-center gap-[1vh]">
                <span class="text-vh-lg text-white font-medium"><%= answer.player.name %></span>
                <span class="text-vh-lg <%= answer.body.present? ? 'text-theme-secondary' : 'text-gray-500 italic' %>
                  <%= 'line-through' if answer.effectively_struck? %>">
                  <%= answer.body.present? ? answer.body : "No answer" %>
                </span>
                <% if answer.duplicate? || answer.auto_duplicate? %>
                  <span class="text-vh-xs bg-theme-secondary/20 text-theme-secondary px-2 py-1 rounded-full font-bold">DUPLICATE</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <p class="text-vh-xl text-theme-secondary animate-pulse">
    Host is reviewing answers...
  </p>
</div>
