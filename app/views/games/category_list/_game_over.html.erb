<%# app/views/games/category_list/_game_over.html.erb %>

<header class="max-w-md mx-auto flex justify-between items-center mb-6 px-2">
  <div class="flex flex-col">
    <span class="text-theme-accent text-xs font-bold tracking-widest uppercase">Game Over</span>
  </div>
  <div class="bg-theme-surface backdrop-blur-md border border-theme-surface-border rounded-xl px-4 py-2 text-center shadow-sm">
    <p class="text-[10px] text-theme-secondary font-bold uppercase tracking-wider">Code</p>
    <p class="text-xl font-black text-white font-mono leading-none"><%= room.code %></p>
  </div>
</header>

<div class="max-w-md mx-auto">
  <div class="bg-theme-surface backdrop-blur-md rounded-3xl p-8 border border-theme-accent-subtle text-center">
    <% rank = room.players.order(score: :desc).pluck(:id).index(player.id)&.+(1) || 0 %>

    <% if rank == 1 %>
      <div class="text-6xl mb-4">🏆</div>
      <p class="text-3xl text-theme-accent font-black mb-2">You Won!</p>
    <% elsif rank <= 3 %>
      <div class="text-6xl mb-4"><%= ["🥈", "🥉"][rank - 2] %></div>
      <p class="text-3xl text-white font-bold mb-2"><%= rank.ordinalize %> Place</p>
    <% else %>
      <div class="text-6xl mb-4">🎮</div>
      <p class="text-3xl text-white font-bold mb-2"><%= rank.ordinalize %> Place</p>
    <% end %>

    <p class="text-5xl text-theme-accent font-black font-mono my-6"><%= player.score %></p>
    <p class="text-lg text-theme-secondary">points</p>
  </div>

  <%= render "shared/feedback_cta" %>

  <!-- Mini Leaderboard -->
  <div class="mt-6 bg-theme-surface backdrop-blur-md rounded-2xl p-4 border border-theme-surface-border">
    <h3 class="text-sm text-theme-secondary font-bold uppercase tracking-wider mb-3">Standings</h3>
    <div class="space-y-2">
      <% room.players.order(score: :desc).limit(5).each_with_index do |p, index| %>
        <div class="flex items-center justify-between <%= p.id == player.id ? 'bg-theme-surface rounded-lg px-2 py-1' : '' %>">
          <div class="flex items-center gap-2">
            <span class="text-theme-text-muted font-bold w-6">#<%= index + 1 %></span>
            <span class="text-white font-medium <%= p.id == player.id ? 'font-bold' : '' %>"><%= p.name %></span>
          </div>
          <span class="text-theme-accent font-bold font-mono"><%= p.score %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>
