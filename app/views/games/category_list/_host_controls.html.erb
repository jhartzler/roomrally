<%# app/views/games/category_list/_host_controls.html.erb %>
<%# Host controls for Category List game during play %>

<% game = room.current_game %>

<div class="space-y-4">
  <% unless game.instructions? %>
    <div class="flex items-center justify-between mb-4">
      <span class="text-blue-200 font-medium">
        Round <%= game.current_round %> of <%= game.total_rounds %> &mdash; Letter "<%= game.current_letter %>"
      </span>
      <span class="px-3 py-1 rounded-full text-sm font-bold
        <%= case game.status
            when 'filling' then 'bg-green-500/20 text-green-300'
            when 'reviewing' then 'bg-blue-500/20 text-blue-300'
            when 'scoring' then 'bg-yellow-500/20 text-yellow-300'
            else 'bg-gray-500/20 text-gray-300'
            end %>">
        <%= game.status.titleize %>
      </span>
    </div>
  <% end %>

  <% if game.instructions? %>
    <p class="text-blue-200 text-sm mb-4">Players are viewing the instructions.</p>
    <%= button_to "Start Game",
        category_list_game_game_start_path(game),
        method: :post,
        class: "w-full bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-500 hover:to-emerald-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>

  <% elsif game.filling? %>
    <% submitted_players = room.players.select { |p| game.current_round_categories.all? { |ci| ci.category_answers.exists?(player: p) } }.count %>
    <p class="text-blue-200 text-sm mb-4">
      Submissions: <%= submitted_players %>/<%= room.players.count %> players
      <% if game.timer_enabled? && game.round_ends_at %>
        <span class="ml-2" data-controller="timer" data-timer-end-value="<%= game.timer_expires_at_iso8601 %>">
          (Timer: <span data-timer-target="output"><%= game.time_remaining.ceil %>s</span>)
        </span>
      <% end %>
    </p>

    <% if room.stage_only? %>
      <%= button_to "Show Scores",
          category_list_game_review_path(game),
          method: :patch,
          class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% else %>
      <%= button_to "End Round",
          category_list_game_review_path(game),
          method: :patch,
          class: "w-full bg-gradient-to-r from-orange-600 to-red-600 hover:from-orange-500 hover:to-red-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% end %>

  <% elsif game.reviewing? %>
    <!-- Show all answers grouped by category with reject buttons -->
    <div class="space-y-4 mb-4 max-h-96 overflow-y-auto">
      <% game.current_round_categories.each do |ci| %>
        <div class="bg-white/5 rounded-xl p-3 border border-white/10">
          <h4 class="text-sm font-bold text-yellow-400 mb-2"><%= ci.name %></h4>
          <% ci.category_answers.includes(:player).each do |answer| %>
            <div class="flex items-center justify-between py-1 border-b border-white/5 last:border-0">
              <div class="flex items-center gap-2">
                <span class="text-white text-sm font-medium"><%= answer.player.name %>:</span>
                <span class="text-blue-200 text-sm <%= answer.body.present? ? '' : 'italic text-gray-500' %>">
                  <%= answer.body.present? ? answer.body : "blank" %>
                </span>
              </div>
              <% if answer.body.present? && !answer.rejected? %>
                <%= button_to "Reject",
                    category_answer_path(answer),
                    method: :patch,
                    params: { category_answer: { status: "rejected" } },
                    class: "text-xs bg-red-600/30 hover:bg-red-600/50 text-red-300 px-2 py-1 rounded-lg transition" %>
              <% elsif answer.rejected? %>
                <span class="text-xs text-red-400">Rejected</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%= button_to "Finish Review & Show Scores",
        category_list_game_review_path(game),
        method: :patch,
        class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>

  <% elsif game.scoring? %>
    <% if game.last_round? %>
      <%= button_to "Finish Game",
          category_list_game_rounds_path(game),
          method: :post,
          class: "w-full bg-gradient-to-r from-yellow-600 to-orange-600 hover:from-yellow-500 hover:to-orange-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% else %>
      <%= button_to "Next Round",
          category_list_game_rounds_path(game),
          method: :post,
          class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% end %>

  <% elsif game.finished? %>
    <div class="bg-green-500/20 rounded-xl p-4 text-center">
      <p class="text-green-300 font-bold text-lg">Game Complete!</p>
      <p class="text-green-200 text-sm mt-2">Final scores are displayed on screen.</p>
    </div>
  <% end %>
</div>
