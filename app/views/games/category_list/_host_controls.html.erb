<%# app/views/games/category_list/_host_controls.html.erb %>
<%# Host controls for Category List game during play %>

<% game = room.current_game %>

<div class="space-y-4">
  <% unless game.instructions? %>
    <div class="flex items-center justify-between mb-4">
      <span class="text-blue-200 font-medium">
        Round <%= game.current_round %> of <%= game.total_rounds %> &mdash; Letter "<%= game.current_letter %>"
      </span>
      <span class="px-3 py-1 rounded-full text-sm font-bold
        <%= case game.status
            when 'filling' then 'bg-green-500/20 text-green-300'
            when 'reviewing' then 'bg-blue-500/20 text-blue-300'
            when 'scoring' then 'bg-yellow-500/20 text-yellow-300'
            else 'bg-gray-500/20 text-gray-300'
            end %>">
        <%= game.status.titleize %>
      </span>
    </div>
  <% end %>

  <% if game.instructions? %>
    <p class="text-blue-200 text-sm mb-4">Players are viewing the instructions.</p>
    <%= button_to "Start Game",
        category_list_game_game_start_path(game),
        method: :post,
        params: { code: room.code },
        data: { turbo_submits_with: "Starting…" },
        class: "w-full bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-500 hover:to-emerald-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>

  <% elsif game.filling? %>
    <% submitted_players = room.players.select { |p| game.current_round_categories.all? { |ci| ci.category_answers.exists?(player: p) } }.count %>
    <p class="text-blue-200 text-sm mb-4">
      Submissions: <%= submitted_players %>/<%= room.players.count %> players
      <% if game.timer_enabled? && game.round_ends_at %>
        <span class="ml-2" data-controller="timer" data-timer-end-value="<%= game.timer_expires_at_iso8601 %>">
          (Timer: <span data-timer-target="output"><%= game.time_remaining.ceil %>s</span>)
        </span>
      <% end %>
    </p>

    <% if room.stage_only? %>
      <%= button_to "Show Scores",
          category_list_game_review_path(game),
          method: :patch,
          params: { code: room.code },
          data: { turbo_submits_with: "Scoring…" },
          class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% else %>
      <%= button_to "End Round",
          category_list_game_review_path(game),
          method: :patch,
          params: { code: room.code },
          data: { turbo_submits_with: "Ending…" },
          class: "w-full bg-gradient-to-r from-orange-600 to-red-600 hover:from-orange-500 hover:to-red-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% end %>

  <% elsif game.reviewing? %>
    <% categories = game.current_round_categories.to_a %>
    <% position = game.reviewing_category_position %>
    <% ci = categories[position] %>
    <% max_position = categories.size - 1 %>

    <p class="text-blue-300 text-xs font-medium mb-3 text-center">
      Category <%= position + 1 %> of <%= categories.size %>
    </p>

    <% if ci %>
      <div class="bg-white/5 rounded-xl p-3 border border-white/10 mb-4">
        <h4 class="text-sm font-bold text-yellow-400 mb-2"><%= ci.name %></h4>
        <%
          answers = ci.category_answers.includes(:player).to_a
          normalized_groups = answers.group_by { |a| Games::CategoryList.send(:normalize_answer, a.body) }
          duplicate_norms = normalized_groups.select { |norm, group| norm.present? && group.size > 1 }.keys.to_set
        %>
        <% answers.each do |answer| %>
          <% norm = Games::CategoryList.send(:normalize_answer, answer.body) %>
          <% is_auto_duplicate = duplicate_norms.include?(norm) && !answer.rejected? && !answer.hidden? && !answer.duplicate? %>
          <% is_struck = answer.rejected? || answer.duplicate? || is_auto_duplicate %>
          <div class="flex items-center justify-between py-1 border-b border-white/5 last:border-0">
            <div class="flex items-center gap-2">
              <span class="text-white text-sm font-medium"><%= answer.player.name %>:</span>
              <span class="text-blue-200 text-sm <%= answer.body.present? ? '' : 'italic text-gray-500' %> <%= 'line-through opacity-50' if is_struck %>">
                <%= answer.body.present? ? answer.body : "blank" %>
              </span>
              <% if answer.hidden? %>
                <span class="text-[10px] bg-gray-400/20 text-gray-400 px-1.5 py-0.5 rounded-full font-bold">HIDDEN</span>
              <% elsif answer.duplicate? || is_auto_duplicate %>
                <span class="text-[10px] bg-orange-400/20 text-orange-400 px-1.5 py-0.5 rounded-full font-bold">DUPLICATE</span>
              <% elsif answer.rejected? %>
                <span class="text-[10px] bg-red-400/20 text-red-400 px-1.5 py-0.5 rounded-full font-bold">0 PTS</span>
              <% end %>
            </div>
            <% if answer.body.present? && !answer.rejected? && !answer.hidden? && !answer.duplicate? %>
              <div class="flex gap-1">
                <%= button_to "Reject",
                    category_answer_path(answer),
                    method: :patch,
                    params: { category_answer: { status: "rejected" }, code: room.code },
                    data: { turbo_submits_with: "…" },
                    class: "text-xs bg-red-600/30 hover:bg-red-600/50 text-red-300 px-2 py-1 rounded-lg transition" %>
                <%= button_to "Duplicate",
                    category_answer_path(answer),
                    method: :patch,
                    params: { category_answer: { status: "duplicate" }, code: room.code },
                    data: { turbo_submits_with: "…" },
                    class: "text-xs bg-orange-600/30 hover:bg-orange-600/50 text-orange-300 px-2 py-1 rounded-lg transition" %>
                <%= button_to "Hide from Audience",
                    category_answer_path(answer),
                    method: :patch,
                    params: { category_answer: { status: "hidden" }, code: room.code },
                    data: { turbo_submits_with: "…" },
                    class: "text-xs bg-gray-600/30 hover:bg-gray-600/50 text-gray-300 px-2 py-1 rounded-lg transition" %>
              </div>
            <% elsif answer.rejected? || answer.duplicate? %>
              <span class="text-xs text-gray-500">0 pts</span>
            <% elsif answer.hidden? %>
              <span class="text-xs text-gray-400">Hidden</span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="flex gap-2 mb-3">
      <%= button_to "← Prev",
          category_list_game_review_navigation_path(game),
          method: :patch,
          params: { direction: "prev", code: room.code },
          disabled: position == 0,
          class: "flex-1 bg-white/10 hover:bg-white/20 disabled:opacity-30 disabled:cursor-not-allowed text-white font-bold py-2 px-4 rounded-xl transition text-sm cursor-pointer" %>
      <%= button_to "Next →",
          category_list_game_review_navigation_path(game),
          method: :patch,
          params: { direction: "next", code: room.code },
          disabled: position == max_position,
          class: "flex-1 bg-white/10 hover:bg-white/20 disabled:opacity-30 disabled:cursor-not-allowed text-white font-bold py-2 px-4 rounded-xl transition text-sm cursor-pointer" %>
    </div>

    <% if position == max_position %>
      <%= button_to "Finish Review & Show Scores",
          category_list_game_review_path(game),
          method: :patch,
          params: { code: room.code },
          data: { turbo_submits_with: "Scoring…" },
          class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% end %>

  <% elsif game.scoring? %>
    <% if room.stage_only? %>
      <% scores_visible = game.show_stage_scores? %>
      <%= button_to scores_visible ? "Hide Scores on Stage" : "Show Scores on Stage",
          category_list_game_stage_scores_path(game),
          method: :patch,
          params: { code: room.code },
          data: { turbo_submits_with: "Updating…" },
          class: "w-full #{scores_visible ? 'bg-white/10 hover:bg-white/20' : 'bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500'} text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10 mb-3" %>
    <% end %>

    <% if game.last_round? %>
      <%= button_to "Finish Game",
          category_list_game_rounds_path(game),
          method: :post,
          params: { code: room.code },
          data: { turbo_submits_with: "Finishing…" },
          class: "w-full bg-gradient-to-r from-yellow-600 to-orange-600 hover:from-yellow-500 hover:to-orange-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% else %>
      <%= button_to "Next Round",
          category_list_game_rounds_path(game),
          method: :post,
          params: { code: room.code },
          data: { turbo_submits_with: "Loading…" },
          class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg cursor-pointer border border-white/10" %>
    <% end %>

  <% elsif game.finished? %>
    <div class="bg-green-500/20 rounded-xl p-4 text-center">
      <p class="text-green-300 font-bold text-lg">Game Complete!</p>
      <p class="text-green-200 text-sm mt-2">Final scores are displayed on screen.</p>
      <%= link_to "Start a new game?", host_path, class: "inline-block mt-3 text-blue-300 hover:text-blue-100 underline text-sm font-medium transition" %>
    </div>
  <% end %>
</div>
