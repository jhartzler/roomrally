<div id="stage_finished"
     class="flex flex-col items-center justify-center flex-1 animate-fade-in"
     data-controller="celebration"
     data-celebration-type-value="trophy">
  <div class="bg-theme-surface backdrop-blur-xl border-2 border-theme-accent-subtle rounded-3xl p-[4vh] text-center max-w-5xl w-full relative overflow-hidden shadow-2xl">
    <div class="absolute inset-0 bg-[url('confetti.svg')] opacity-20"></div>

    <h2 class="text-vh-5xl font-black text-transparent bg-clip-text bg-gradient-to-tr from-yellow-300 via-yellow-100 to-yellow-500 mb-[3vh] drop-shadow-xl animate-bounce-in">
      Game Over!
    </h2>

    <div class="space-y-[2vh]">
      <% game.room.players.active_players.order(score: :desc).each_with_index do |player, index| %>
        <div class="flex items-center bg-black/40 rounded-xl p-[2vh] border border-theme-surface-border <%= index == 0 ? 'border-2 border-theme-accent-subtle shadow-[0_0_30px_rgba(234,179,8,0.3)] animate-bounce-in' : '' %>">
          <div class="text-vh-3xl w-[8vh] font-bold <%= index == 0 ? 'text-theme-accent' : 'text-gray-400' %>">#<%= index + 1 %></div>
          <div class="text-vh-3xl font-bold text-white flex-grow text-left mx-[2vh]"><%= player.name %></div>
          <div class="text-vh-4xl font-black text-theme-accent font-mono"><%= player.score %></div>
          <% if index == 0 %>
            <div class="text-vh-4xl ml-[1vh]">🏆</div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-[4vh]">
      <p class="text-vh-xl text-gray-400">Host can start a new game anytime.</p>
    </div>
  </div>
</div>
