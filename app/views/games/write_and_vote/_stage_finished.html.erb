<div id="stage_finished"
     class="flex flex-col items-center justify-center flex-1"
     data-controller="celebration"
     data-celebration-type-value="trophy">
  <div class="bg-white/10 backdrop-blur-xl border-2 border-yellow-400/30 rounded-3xl p-[4vh] text-center max-w-5xl w-full relative overflow-hidden shadow-2xl">
    <div class="absolute inset-0 bg-[url('confetti.svg')] opacity-20"></div>

    <h2 class="text-vh-5xl font-black text-transparent bg-clip-text bg-gradient-to-tr from-yellow-300 via-yellow-100 to-yellow-500 mb-[2vh] drop-shadow-xl animate-bounce-in">
      Game Over!
    </h2>

    <% top_players = game.room.players.active_players.order(score: :desc).limit(2) %>
    <% if top_players.any? { |p| p.score > 0 } %>
      <div class="mb-[2vh]">
        <div class="text-vh-sm uppercase tracking-[0.2em] text-yellow-400 mb-[1.5vh]">Best Lines</div>
        <div class="flex gap-[2vh] justify-center">
          <% top_players.each_with_index do |player, index| %>
            <% best = game.best_response_for(player) %>
            <% next unless best&.votes&.any? %>
            <div class="flex-1 max-w-md <%= index == 0 ? 'bg-yellow-400/10 border-yellow-400/30' : 'bg-white/5 border-white/15' %> border rounded-2xl p-[2vh] text-center">
              <div class="text-vh-xs text-gray-400 italic mb-[0.5vh] line-clamp-1"><%= best.prompt_instance.body %></div>
              <div class="text-vh-lg <%= index == 0 ? 'text-yellow-100' : 'text-gray-200' %> italic font-medium mb-[1vh]">"<%= best.body %>"</div>
              <div class="text-vh-sm <%= index == 0 ? 'text-yellow-400' : 'text-gray-400' %>"><%= index == 0 ? '🏆' : '🥈' %> <%= player.name %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="space-y-[2vh]">
      <% game.room.players.active_players.order(score: :desc).each_with_index do |player, index| %>
        <div class="flex items-center bg-black/40 rounded-xl p-[2vh] border border-white/10 <%= index == 0 ? 'border-2 border-yellow-400/50 shadow-[0_0_30px_rgba(234,179,8,0.3)] animate-bounce-in' : '' %>">
          <div class="text-vh-3xl w-[8vh] font-bold <%= index == 0 ? 'text-yellow-400' : 'text-gray-400' %>">#<%= index + 1 %></div>
          <div class="text-vh-3xl font-bold text-white flex-grow text-left mx-[2vh]"><%= player.name %></div>
          <div class="text-vh-4xl font-black text-yellow-400 font-mono"><%= player.score %></div>
          <% if index == 0 %>
            <div class="text-vh-4xl ml-[1vh]">🏆</div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-[4vh]">
      <p class="text-vh-xl text-gray-400">Host can start a new game anytime.</p>
    </div>
  </div>
</div>
