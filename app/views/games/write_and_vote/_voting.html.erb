<%# app/views/games/write_and_vote/_voting.html.erb %>
<div class="voting-screen text-white" data-render-time="<%= Time.now.to_f %>">
  <% current_game = room.current_game %>
  <% current_prompt = current_game.current_round_prompts.order(:id)[current_game.current_prompt_index] %>

  <!-- Progress Indicator -->
  <div class="bg-white/10 backdrop-blur-md rounded-xl px-4 py-2 mb-4 text-center">
    <p class="text-xs text-blue-200 font-bold uppercase tracking-wider">
      Round <%= current_game.round %> • Prompt <%= current_game.current_prompt_index + 1 %> of <%= current_game.current_round_prompts.count %>
    </p>
  </div>

  <!-- Timer -->
  <div class="mb-6 flex justify-center">
    <% if game.timer_enabled? %>
      <div data-controller="dramatic-timer"
           data-dramatic-timer-end-value="<%= game.timer_expires_at_iso8601 %>"
           data-dramatic-timer-target="container"
           class="bg-blue-950/40 backdrop-blur-md rounded-xl px-4 py-3 text-center border border-blue-400/30 shadow-lg flex flex-col items-center gap-1 transition-all">
        <div class="rounded-lg px-4 py-1">
          <span class="text-3xl font-black text-white block font-mono leading-none drop-shadow-md"
                data-dramatic-timer-target="output"><%= game.time_remaining.ceil %>s</span>
        </div>
        <span class="text-[10px] font-black tracking-widest text-blue-400 uppercase"
              data-dramatic-timer-target="visual">Time Left</span>
      </div>
    <% end %>
  </div>

  <h2 class="text-xl font-bold mb-4 text-center drop-shadow-md">Vote for the best answer!</h2>

  <div class="prompt-display mb-6 p-6 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 text-center shadow-lg">
    <p class="text-xl font-bold italic text-blue-100"><%= current_prompt&.prompt&.body %></p>
  </div>

  <div class="responses-list space-y-4">
    <% responses = current_prompt.responses %>
    <% if responses.exists?(player: player) %>
      <div class="text-center p-8 bg-white/5 backdrop-blur-md rounded-xl border border-white/10 flex flex-col items-center">
        <div class="text-4xl mb-3 animate-bounce">🗳️</div>
        <h3 class="text-xl font-bold text-white mb-2">Your answer is up for a vote!</h3>
        <p class="text-blue-200">Sit tight — the room is deciding if you're a comedy genius or just... brave.</p>
        <p class="text-blue-300/50 text-xs mt-4 animate-pulse uppercase tracking-widest font-bold">Waiting for everyone to vote...</p>
      </div>
    <% else %>
      <%
         player_vote = Vote.joins(:response)
                          .where(player: player)
                          .where(responses: { prompt_instance_id: current_prompt.id })
                          .first
         available_responses = responses.order(:id)
      %>
      <% if player_vote.present? %>
        <%# Show only the card the player voted for — others don't render %>
        <% voted_response = available_responses.find { |r| r.id == player_vote.response_id } %>
        <% if voted_response %>
          <div class="response-card bg-blue-600/20 backdrop-blur-sm p-6 rounded-2xl border border-green-400/30 shadow-sm">
            <div class="text-center">
              <div class="text-xl font-bold text-white mb-4 leading-relaxed">"<%= voted_response.body %>"</div>
              <div class="flex items-center justify-center gap-2 text-green-400 font-bold">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Vote cast!</span>
              </div>
              <p class="text-blue-300/70 text-sm mt-3">Waiting for others...</p>
            </div>
          </div>
        <% end %>
      <% else %>
        <%# No vote yet — show all response cards with vote buttons %>
        <% available_responses.each do |response| %>
          <div class="response-card bg-blue-600/20 backdrop-blur-sm p-6 rounded-2xl border border-blue-400/30 shadow-sm transition-all"
               data-controller="vote-feedback">
            <div class="text-xl font-bold text-white mb-4 leading-relaxed text-center">
              "<%= response.body %>"
            </div>

            <%= button_to "Vote for this answer",
                votes_path,
                params: { vote: { response_id: response.id }, code: room.code },
                data: { action: "click->vote-feedback#vote" },
                class: "w-full bg-orange-500 hover:bg-orange-600 active:scale-[0.95] text-white font-black py-3 rounded-xl shadow-lg transition-all" %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
