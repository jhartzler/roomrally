<%# app/views/games/write_and_vote/_hand.html.erb %>
<%# Main view router for a player's hand in Write and Vote %>

<% game = room.current_game %>

<% if game.instructions? %>
  <%= render "games/shared/hand_instructions",
      emoji: "✍️",
      start_game_path: write_and_vote_game_game_start_path(game),
      room:,
      player: %>
<% elsif game.finished? %>
  <%= render "games/write_and_vote/game_over", room:, player: %>
<% elsif game.voting? %>
  <%= render "games/write_and_vote/voting", room:, player:, game: %>
<% else %>
  <%
    player_prompt_instances = player.responses.joins(:prompt_instance)
                                    .where(prompt_instances: { round: game.round })
                                    .map(&:prompt_instance)
  %>
  <%= render "games/write_and_vote/prompt_screen", player:, prompts: player_prompt_instances, room:, game: %>
<% end %>
