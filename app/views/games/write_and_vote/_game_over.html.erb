<div class="flex flex-col items-center justify-center min-h-[50vh] space-y-8 animate-fade-in">
  <h1 class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600 drop-shadow-lg">
    Game Over!
  </h1>
  
  <div class="text-2xl text-slate-300 font-medium">
    Thanks for playing!
  </div>

  <div class="p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 backdrop-blur-sm shadow-xl">
    <p class="text-slate-400 text-center">
      Results coming soon...
    </p>
  </div>

  <%= link_to "Back to Home", root_path, class: "px-8 py-4 bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold rounded-full shadow-lg transform transition hover:scale-105 active:scale-95" %>
</div>
