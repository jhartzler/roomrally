<div id="stage_writing" class="flex flex-col items-center justify-center max-h-[88vh] animate-fade-in">
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-[4vh] shadow-2xl text-center max-w-4xl">
    <div class="text-[8vh] mb-[2vh] animate-pulse">📱</div>

    <div class="mb-[2vh]"
         data-controller="dramatic-timer"
         data-dramatic-timer-end-value="<%= game.timer_expires_at_iso8601 %>">
       <span class="text-vh-5xl font-black text-white block font-mono"
             data-dramatic-timer-target="output visual"><%= game.time_remaining.ceil %>s</span>
    </div>

    <h2 class="text-vh-3xl font-bold text-white mb-[2vh]">Look at your device!</h2>
    <p class="text-vh-2xl text-blue-200 font-medium">
      Writing Phase: Round <%= game.round %>
    </p>
    <div class="mt-[3vh] w-full bg-white/10 h-[0.5vh] rounded-full overflow-hidden border border-white/10">
      <div class="bg-gradient-to-r from-blue-400 to-blue-600 h-full w-full animate-shrink-width" style="animation-duration: 90s;"></div>
    </div>
  </div>
</div>
