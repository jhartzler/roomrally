<div id="stage_writing" class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
  <div class="bg-indigo-900/50 backdrop-blur-xl border border-indigo-500/30 rounded-3xl p-16 shadow-2xl text-center max-w-4xl">
    <div class="text-9xl mb-8 animate-bounce">📱</div>

    <div class="mb-8" data-controller="timer" data-timer-end-value="<%= game.timer_expires_at_iso8601 %>">
       <span class="text-8xl font-black text-white block font-mono" data-timer-target="output">30s</span>
    </div>

    <h2 class="text-4xl font-bold text-white mb-8">Look at your device!</h2>
    <p class="text-3xl text-indigo-200 font-medium">
      Writing Phase: Round <%= game.round %>
    </p>
    <div class="mt-12 w-full bg-gray-700/50 h-4 rounded-full overflow-hidden">
      <div class="bg-gradient-to-r from-indigo-500 to-purple-500 h-full w-full animate-shrink-width" style="animation-duration: 90s;"></div>
    </div>
  </div>
</div>
