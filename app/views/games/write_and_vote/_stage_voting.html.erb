<div id="stage_voting" class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
  <!-- Prompt Display -->
  <div class="relative bg-gradient-to-br from-purple-900/80 to-indigo-900/80 backdrop-blur-xl border border-white/20 rounded-3xl p-12 shadow-2xl text-center max-w-6xl w-full mb-12 transform hover:scale-[1.02] transition-transform">
    
    <div class="absolute top-6 right-8" data-controller="timer" data-timer-end-value="<%= game.timer_expires_at_iso8601 %>">
       <span class="text-5xl font-black text-white/50 block font-mono" data-timer-target="output visual"><%= game.time_remaining.ceil %>s</span>
    </div>
    <% current_prompt = game.current_round_prompts.order(:id)[game.current_prompt_index] %>
    <p class="text-2xl text-purple-300 font-bold uppercase tracking-widest mb-4">Prompt</p>
    <h2 class="text-5xl md:text-7xl font-black text-white leading-tight">
      <%= current_prompt&.body || "Loading prompt..." %>
    </h2>
  </div>

  <!-- Responses Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-7xl px-4">
    <% if current_prompt %>
      <% current_prompt.responses.shuffle.each_with_index do |response, index| %>
        <div class="bg-gray-800/80 backdrop-blur-md border-2 border-gray-600 rounded-2xl p-8 flex items-center shadow-lg">
          <div class="bg-white text-black font-black text-4xl h-16 w-16 rounded-full flex items-center justify-center mr-6 shrink-0 shadow-md">
            <%= (index + 65).chr %>
          </div>
          <p class="text-3xl md:text-4xl text-white font-bold font-handwriting">
            <%= response.body %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-12">
    <p class="text-3xl text-indigo-300 animate-pulse font-semibold">Cast your votes now!</p>
  </div>
</div>
