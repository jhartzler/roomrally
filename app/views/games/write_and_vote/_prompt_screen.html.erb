<%# app/views/games/write_and_vote/_prompt_screen.html.erb %>
<div class="text-center">
  <div data-controller="timer" data-timer-end-value="<%= room.current_round_timer_value %>" class="mb-4">
    <span class="text-4xl font-black text-indigo-600 block" data-timer-target="output">30s</span>
    <span class="text-xs font-bold uppercase tracking-widest text-indigo-600" data-timer-target="visual">Time Left</span>
  </div>

  <h2 class="text-3xl font-black text-gray-800 mb-2">Your Prompts</h2>
  <p class="text-gray-600">Choose a prompt and write your answer.</p>
</div>

<div class="mt-8 space-y-4">
  <% prompts.each do |prompt| %>
    <% response = player.responses.find_by(prompt_instance: prompt) %>
    <div id="prompt-instance-<%= prompt.id %>" data-test-id="player-prompt">
      <div class="bg-gray-100 p-4 rounded-lg">
        <p class="font-semibold"><%= prompt.body %></p>
        <form action="<%= response_path(response) %>" method="post">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <textarea name="response[body]" class="w-full border-gray-300 rounded-md mt-2" placeholder="Write your answer..."></textarea>
          <input type="submit" value="Submit" class="w-full bg-blue-500 text-white font-bold py-2 px-4 rounded-md mt-2">
        </form>
      </div>
    </div>
  <% end %>
</div>

