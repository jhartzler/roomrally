<%# app/views/games/write_and_vote/_prompt_screen.html.erb %>
<div class="text-center">
  <% if game.timer_enabled? %>
    <div data-controller="timer" data-timer-end-value="<%= game.timer_expires_at_iso8601 %>" class="mb-4">
      <span class="text-4xl font-black text-indigo-600 block" data-timer-target="output"><%= game.time_remaining.ceil %>s</span>
      <span class="text-xs font-bold uppercase tracking-widest text-indigo-600" data-timer-target="visual">Time Left</span>
    </div>
  <% end %>

  <h2 class="text-3xl font-black text-gray-800 mb-2">Your Prompts</h2>
  <p class="text-gray-600">Choose a prompt and write your answer.</p>
</div>

<div class="mt-8 space-y-4">
  <% prompts.each do |prompt| %>
    <% response = player.responses.find_by(prompt_instance: prompt) %>
    <% if response.pending? || response.rejected? %>
      <%= render "responses/form", response: response, prompt: prompt %>
    <% else %>
      <div id="prompt-instance-<%= prompt.id %>" data-test-id="player-prompt">
        <%= render "responses/submission_success", response: response %>
      </div>
    <% end %>
  <% end %>
</div>

