<%# app/views/games/write_and_vote/_prompt_screen.html.erb %>
<div class="text-center">
  <h2 class="text-3xl font-black text-gray-800 mb-2">Your Prompts</h2>
  <p class="text-gray-600">Choose a prompt and write your answer.</p>
</div>

<div class="mt-8 space-y-4">
  <% prompts.each do |prompt| %>
    <div data-test-id="player-prompt" class="bg-gray-100 p-4 rounded-lg">
      <p class="font-semibold"><%= prompt.body %></p>
      <form>
        <input type="text" class="w-full border-gray-300 rounded-md mt-2" placeholder="Write your answer...">
        <button type="submit" class="w-full bg-blue-500 text-white font-bold py-2 px-4 rounded-md mt-2">Submit</button>
      </form>
    </div>
  <% end %>
</div>
