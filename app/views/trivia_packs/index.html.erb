<div class="p-4 md:p-8 font-sans">
  <header class="max-w-5xl mx-auto mb-10 flex justify-between items-end">
    <div>
      <h1 class="text-4xl font-black text-white tracking-tighter drop-shadow-md">
        Trivia Library
    </h1>
    <p class="text-blue-200 font-medium">Your trivia pack library</p>
  </div>

  <div class="flex items-center gap-4">
    <%= link_to new_trivia_pack_path, class: "inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all transform hover:scale-105 active:scale-95" do %>
      <%= lucide_icon('plus', class: "w-5 h-5", "aria-hidden": true) %>
      <span>New Pack</span>
    <% end %>
  </div>
</header>

<!-- Template Gallery Section -->
<section class="max-w-5xl mx-auto mb-12">
  <h2 class="text-xl font-black text-white mb-1 flex items-center gap-2 tracking-wide">
    <%= lucide_icon('layout-template', class: "w-6 h-6 text-blue-200/50", "aria-hidden": true) %>
    Template Gallery
  </h2>
  <p class="text-blue-200/50 text-sm mb-6 ml-8">Ready-made packs to get you started</p>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <% @system_packs.each do |pack| %>
      <%= render "card", pack: pack, variant: :system %>
    <% end %>

    <% if @system_packs.empty? %>
        <div class="col-span-full text-center py-8 text-blue-200/50 font-medium italic">
          No system templates available.
        </div>
      <% end %>
    </div>
  </section>

  <!-- My Packs Section -->
  <section class="max-w-5xl mx-auto mb-12">
    <h2 class="text-xl font-black text-white mb-1 flex items-center gap-2 tracking-wide">
      <%= lucide_icon('folder-open', class: "w-6 h-6 text-blue-200/50", "aria-hidden": true) %>
      My Packs
    </h2>
    <p class="text-blue-200/50 text-sm mb-6 ml-8">Packs you've created</p>

    <% if @trivia_packs.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @trivia_packs.each do |pack| %>
          <%= render "card", pack: pack, variant: :user %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20 bg-white/5 backdrop-blur-md rounded-3xl border-2 border-dashed border-white/10">
        <div class="mx-auto w-20 h-20 bg-white/5 rounded-full flex items-center justify-center text-blue-200/30 mb-6">
          <%= lucide_icon('folder-plus', class: "w-10 h-10", "aria-hidden": true) %>
        </div>
        <h3 class="text-2xl font-black text-white mb-2">No Trivia Packs Yet</h3>
        <p class="text-blue-200 font-medium mb-8 max-w-sm mx-auto">Create your first pack to start organizing your custom trivia questions.</p>
        <%= link_to new_trivia_pack_path, class: "inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-8 rounded-xl shadow-lg transition-all transform hover:scale-105 active:scale-95" do %>
          <%= lucide_icon('plus', class: "w-5 h-5", "aria-hidden": true) %>
          <span>Create Trivia Pack</span>
        <% end %>
      </div>
    <% end %>
  </section>

  <!-- Info Box -->
  <section class="max-w-5xl mx-auto">
    <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 bg-blue-500/20 rounded-full flex items-center justify-center border border-blue-400/30">
          <%= lucide_icon('lightbulb', class: "w-5 h-5 text-blue-300") %>
        </div>
        <div>
          <h3 class="font-bold text-white mb-2">Tips for great trivia</h3>
          <p class="text-blue-200/80 text-sm leading-relaxed">
            Each pack is a set of multiple-choice questions. During the game, questions show up on the Stage (the big screen) and
            players race to answer on their phones. Keep questions punchy — players are on the clock. Every game comes with default
            questions, so custom packs are totally optional.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>
