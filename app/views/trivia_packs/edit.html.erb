<div class="p-6 md:p-12 font-sans">
  <div class="max-w-7xl mx-auto">
    <header class="mb-8 flex justify-between items-start">
      <div>
        <%= link_to trivia_packs_path, class: "group flex items-center gap-2 text-blue-200 hover:text-white transition-colors font-bold mb-4 w-fit" do %>
          <div class="p-2 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors border border-white/10">
            <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
          </div>
          <span>Back to Library</span>
        <% end %>

        <h1 class="text-4xl font-black text-white tracking-tighter drop-shadow-md">
          Edit Trivia Pack
        </h1>
        <p class="text-blue-200 font-medium mt-1">Update your trivia question pack</p>
      </div>
      <%= button_to "Delete Pack", @trivia_pack, method: :delete, class: "text-red-500 hover:text-red-700 font-bold text-sm bg-red-50 hover:bg-red-100 px-4 py-2 rounded-lg transition-colors", form: { data: { turbo_confirm: "Are you sure?" } } %>
    </header>

    <%= render "ai_generation_requests/panel", pack: @trivia_pack, pack_type: "trivia_pack" %>
    <%= render "form", trivia_pack: @trivia_pack %>
  </div>
</div>
