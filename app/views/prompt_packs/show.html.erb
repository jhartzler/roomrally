<div class="min-h-screen bg-slate-50 p-6 md:p-12 font-sans">
  <div class="max-w-4xl mx-auto">
    <!-- Header / Navigation -->
    <div class="flex items-center justify-between mb-8">
      <%= link_to prompt_packs_path, class: "group flex items-center gap-2 text-slate-500 hover:text-blue-600 transition-colors font-bold" do %>
        <div class="p-2 rounded-full bg-slate-200 group-hover:bg-blue-100 transition-colors">
           <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
        </div>
        <span>Back to Library</span>
      <% end %>

      <div class="flex items-center gap-3">
        <%= button_to rooms_path(game_type: @prompt_pack.game_type, prompt_pack_id: @prompt_pack.id), method: :post, class: "inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-5 rounded-lg shadow-md transition-all transform hover:scale-105" do %>
          <%= lucide_icon('play', class: "w-4 h-4") %>
          <span>Play Pack</span>
        <% end %>

        <% if @prompt_pack.user == current_user %>
          <%= link_to edit_prompt_pack_path(@prompt_pack), class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-5 rounded-lg shadow-md transition-all transform hover:scale-105" do %>
            <%= lucide_icon('edit-3', class: "w-4 h-4") %>
            <span>Edit Pack</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Content Card -->
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
      
      <!-- Top Banner area -->
      <div class="bg-gradient-to-r from-slate-100 to-slate-50 p-8 border-b border-slate-100">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl font-black text-slate-900"><%= @prompt_pack.name %></h1>
              <% if @prompt_pack.user.nil? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide bg-blue-100 text-blue-700">
                  System Pack
                </span>
              <% else %>
                 <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold <%= @prompt_pack.live? ? 'bg-green-100 text-green-800' : 'bg-slate-100 text-slate-600' %>">
                   <div class="w-2 h-2 rounded-full <%= @prompt_pack.live? ? 'bg-green-500' : 'bg-slate-400' %>"></div>
                   <%= @prompt_pack.status.humanize %>
                 </span>
              <% end %>
            </div>
            <p class="text-slate-500 font-medium text-lg flex items-center gap-2">
              <%= lucide_icon('gamepad-2', class: "w-5 h-5 text-slate-400") %>
              <%= @prompt_pack.game_type %>
            </p>
          </div>

          <div class="flex items-center gap-4">
             <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-200 text-center min-w-[100px]">
                <span class="block text-3xl font-black text-slate-900"><%= @prompt_pack.prompts.count %></span>
                <span class="text-xs font-bold text-slate-500 uppercase tracking-wide">Prompts</span>
             </div>
             <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-200 text-center min-w-[100px]">
                <span class="block text-3xl font-black text-slate-900"><%= @prompt_pack.supported_players_count || 0 %></span>
                <span class="text-xs font-bold text-slate-500 uppercase tracking-wide">Players</span>
             </div>
          </div>
        </div>
      </div>

      <!-- Prompts List -->
      <div class="p-8 bg-white">
        <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2 pb-4 border-b border-slate-100">
          <%= lucide_icon('list', class: "w-5 h-5 text-slate-400") %>
          Prompts Included
        </h2>
        
        <% if @prompt_pack.prompts.any? %>
          <div class="grid grid-cols-1 gap-3">
            <% @prompt_pack.prompts.each do |prompt| %>
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100 text-slate-700 font-medium hover:bg-slate-100 transition-colors flex items-start gap-3">
                 <span class="mt-1 text-slate-400">
                    <%= lucide_icon('message-square', class: "w-4 h-4") %>
                 </span>
                 <%= prompt.body %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12 bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
             <p class="text-slate-400 font-medium">This pack has no prompts yet.</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
