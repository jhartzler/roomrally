<div class="p-4 md:p-8">
  <div class="max-w-4xl mx-auto">
    <!-- Header / Navigation -->
    <div class="flex items-center justify-end mb-8">
      <div class="flex items-center gap-3">
        <% if @prompt_pack.user == current_user %>
          <%= link_to edit_prompt_pack_path(@prompt_pack), class: "inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-5 rounded-lg shadow-md transition-all transform hover:scale-105 active:scale-95" do %>
            <%= lucide_icon('edit-3', class: "w-4 h-4") %>
            <span>Edit Pack</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Play Pack Card -->
    <div class="bg-white/10 backdrop-blur-md rounded-xl p-4 border border-white/20 mb-8">
      <%= form_with url: rooms_path, method: :post, class: "space-y-3" do |form| %>
        <%= form.hidden_field :game_type, value: @prompt_pack.game_type %>
        <%= form.hidden_field :prompt_pack_id, value: @prompt_pack.id %>

        <div>
          <%= form.label :display_name, "Game Name (optional)", class: "block text-blue-200 text-xs font-bold mb-1" %>
          <%= form.text_field :display_name, placeholder: "Leave blank for default", class: "w-full px-3 py-2 bg-white/20 border border-white/10 rounded-lg text-white placeholder-white/40 text-sm focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 transition-all" %>
        </div>

        <%= form.submit "Play Pack", class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg shadow-md transition-all transform hover:scale-[1.02] active:scale-[0.98] cursor-pointer flex items-center justify-center gap-2" %>
      <% end %>
    </div>

    <!-- Content Card -->
    <div class="bg-white/10 backdrop-blur-md rounded-3xl shadow-2xl overflow-hidden border border-white/20">

      <!-- Top Banner area -->
      <div class="bg-white/5 p-8 border-b border-white/10">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl font-black text-white"><%= @prompt_pack.name %></h1>
              <% if @prompt_pack.user.nil? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide bg-blue-500/20 text-blue-200 border border-blue-400/30">
                  System Pack
                </span>
              <% else %>
                 <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold <%= @prompt_pack.live? ? 'bg-green-500/20 text-green-300' : 'bg-white/10 text-slate-300' %> border border-white/10">
                   <div class="w-2 h-2 rounded-full <%= @prompt_pack.live? ? 'bg-green-400 animate-pulse' : 'bg-slate-400' %>"></div>
                   <%= @prompt_pack.status.humanize %>
                 </span>
              <% end %>
            </div>
            <p class="text-blue-200 font-medium text-lg flex items-center gap-2">
              <%= lucide_icon('gamepad-2', class: "w-5 h-5 text-blue-300") %>
              <%= @prompt_pack.game_type %>
            </p>
          </div>

          <div class="flex items-center gap-4">
             <div class="bg-white/5 p-4 rounded-2xl shadow-lg border border-white/10 text-center min-w-[100px] backdrop-blur-sm">
                <span class="block text-3xl font-black text-white"><%= @prompt_pack.prompts.count %></span>
                <span class="text-xs font-bold text-blue-300 uppercase tracking-widest">Prompts</span>
             </div>
             <% if @prompt_pack.has_player_limit? %>
               <div class="bg-white/5 p-4 rounded-2xl shadow-lg border border-white/10 text-center min-w-[100px] backdrop-blur-sm">
                  <span class="block text-3xl font-black text-white"><%= @prompt_pack.supported_players_count %></span>
                  <span class="text-xs font-bold text-blue-300 uppercase tracking-widest">Players</span>
               </div>
             <% end %>
          </div>
        </div>
      </div>

      <!-- Prompts List -->
      <div class="p-8 bg-black/20">
        <h2 class="text-lg font-bold text-white mb-6 flex items-center gap-2 pb-4 border-b border-white/10 tracking-wide">
          <%= lucide_icon('list', class: "w-5 h-5 text-blue-300") %>
          Prompts Included
        </h2>

        <% if @prompt_pack.prompts.any? %>
          <div class="grid grid-cols-1 gap-3">
            <% @prompt_pack.prompts.each do |prompt| %>
              <div class="p-4 rounded-xl bg-white/5 border border-white/10 text-blue-50 font-medium hover:bg-white/10 transition-colors flex items-start gap-3">
                 <span class="mt-1 text-blue-300">
                    <%= lucide_icon('message-square', class: "w-4 h-4") %>
                 </span>
                 <%= prompt.body %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12 bg-white/5 rounded-2xl border-2 border-dashed border-white/10">
             <p class="text-blue-300/50 font-medium">This pack has no prompts yet.</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
