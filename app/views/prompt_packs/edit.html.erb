<div class="p-4 md:p-8">
  <div class="max-w-5xl mx-auto">
    <header class="mb-10 flex justify-between items-start">
      <div>
        <h1 class="text-4xl font-black text-white mb-2 tracking-tighter drop-shadow-md">Edit Prompt Pack</h1>
        <p class="text-blue-200 font-medium">Refining your prompts.</p>
      </div>
      <%= button_to "Delete Pack", @prompt_pack, method: :delete, class: "text-red-500 hover:text-red-700 font-bold text-sm bg-red-50 hover:bg-red-100 px-4 py-2 rounded-lg transition-colors", form: { data: { turbo_confirm: "Are you sure?" } } %>
    </header>

    <%= render "ai_generation_requests/panel", pack: @prompt_pack, pack_type: "prompt_pack" %>
    <%= render "form", prompt_pack: @prompt_pack %>
  </div>
</div>
