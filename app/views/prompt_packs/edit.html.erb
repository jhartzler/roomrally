<div class="min-h-screen bg-slate-50 p-6 md:p-12 font-sans">
  <div class="max-w-5xl mx-auto">
    <header class="mb-10 flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600 mb-2">Edit Prompt Pack</h1>
        <p class="text-slate-500 font-medium">Refining your prompts.</p>
      </div>
      <%= button_to "Delete Pack", @prompt_pack, method: :delete, class: "text-red-500 hover:text-red-700 font-bold text-sm bg-red-50 hover:bg-red-100 px-4 py-2 rounded-lg transition-colors", form: { data: { turbo_confirm: "Are you sure?" } } %>
    </header>
    
    <%= render "form", prompt_pack: @prompt_pack %>
  </div>
</div>
