<div class="p-6 md:p-12 font-sans">
  <div class="max-w-5xl mx-auto">
    <header class="mb-10">
      <%= link_to prompt_packs_path, class: "group flex items-center gap-2 text-blue-200 hover:text-white transition-colors font-bold mb-4 w-fit" do %>
        <div class="p-2 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors border border-white/10">
          <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
        </div>
        <span>Back to Library</span>
      <% end %>

      <h1 class="text-4xl font-black text-white mb-2 tracking-tighter drop-shadow-md">New Prompt Pack</h1>
      <p class="text-blue-200 font-medium">Create a new prompt pack</p>
    </header>
    
    <%= render "ai_generation_requests/panel", pack: @prompt_pack, pack_type: "prompt_pack" %>
    <%= render "form", prompt_pack: @prompt_pack %>
  </div>
</div>
