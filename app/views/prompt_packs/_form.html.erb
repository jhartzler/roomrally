<%= form_with(model: prompt_pack, class: "contents", data: { controller: "content-editor", content_editor_ratio_value: prompt_pack.prompts_per_player_ratio }) do |form| %>
  <% if prompt_pack.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-600 px-6 py-4 font-medium rounded-2xl mb-8 border border-red-100">
      <h2 class="font-bold mb-2"><%= pluralize(prompt_pack.errors.count, "error") %> prohibited this pack from being saved:</h2>
      <ul class="list-disc list-inside text-sm">
        <% prompt_pack.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Left Column: Settings -->
    <div class="space-y-6">
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
        <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center gap-2">
           <%= lucide_icon('settings', class: "w-5 h-5 text-slate-400") %>
           Pack Settings
        </h3>
        
        <div class="space-y-5">
          <div>
            <%= form.label :name, class: "block text-sm font-bold text-slate-700 mb-2" %>
            <%= form.text_field :name, class: "block w-full rounded-xl border-2 border-slate-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 transition-all font-medium py-3 px-4 text-slate-800" %>
          </div>

          <div>
            <%= form.label :game_type, class: "block text-sm font-bold text-slate-700 mb-2" %>
            <%= form.select :game_type, Room::GAME_TYPES, {}, class: "block w-full rounded-xl border-2 border-slate-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 transition-all font-medium py-3 px-4 text-slate-800" %>
          </div>

           <div>
            <%= form.label :status, class: "block text-sm font-bold text-slate-700 mb-2" %>
            <%= form.select :status, PromptPack.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "block w-full rounded-xl border-2 border-slate-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 transition-all font-medium py-3 px-4 text-slate-800" %>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 p-8 rounded-3xl border border-blue-100">
        <h3 class="font-black text-blue-700 mb-2 flex items-center gap-2">
          <%= lucide_icon('users', class: "w-5 h-5") %>
          Capacity Check
        </h3>
        <p class="text-slate-600 text-sm font-medium mb-1">
          Supports up to <span data-content-editor-target="countDisplay" class="font-black text-lg text-slate-900">0</span> players.
        </p>
        <p class="text-xs text-blue-500/80 font-bold tracking-wide uppercase">Based on current prompt count. Max 20 recommended.</p>
      </div>

       <div class="pt-2">
        <%= form.submit "Save Pack", class: "w-full rounded-xl py-4 px-6 bg-indigo-600 hover:bg-indigo-700 text-white block font-black text-lg shadow-lg shadow-indigo-200 transition-all cursor-pointer transform hover:scale-[1.02]" %>
        <%= link_to "Cancel", prompt_packs_path, class: "block w-full text-center mt-4 text-slate-400 hover:text-slate-600 font-bold text-sm transition-colors" %>
      </div>
    </div>

    <!-- Right Column: Prompts -->
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200 h-fit">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-black text-slate-900">Prompts</h3>
         <button type="button" data-action="content-editor#addPrompt" class="text-sm text-indigo-600 hover:text-indigo-800 font-bold bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1.5">
            <%= lucide_icon('plus', class: "w-4 h-4") %>
            Add Prompt
         </button>
      </div>

      <div data-content-editor-target="promptList" class="space-y-4">
        <%= form.fields_for :prompts do |prompt_form| %>
          <div class="prompt-field-wrapper flex gap-3 items-start group" data-new-record="<%= prompt_form.object.new_record? %>">
            <%= prompt_form.text_area :body, rows: 2, class: "block w-full rounded-xl border-2 border-slate-100 focus:border-indigo-500 focus:ring focus:ring-indigo-200 text-sm font-medium text-slate-700 placeholder-slate-300 resize-none transition-all px-4 py-3", data: { content_editor_target: "promptField", action: "input->content-editor#updateCount" }, placeholder: "Enter a prompt..." %>
            <%= prompt_form.hidden_field :_destroy %>
            <div class="pt-2">
              <button type="button" data-action="content-editor#removePrompt" class="text-slate-300 hover:text-red-500 p-1 opacity-0 group-hover:opacity-100 transition-all transform hover:scale-110">
                <%= lucide_icon('trash-2', class: "w-5 h-5") %>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Hidden Template for New Fields -->
  <template data-content-editor-target="promptTemplate">
    <div class="prompt-field-wrapper flex gap-3 items-start group" data-new-record="true">
      <textarea name="prompt_pack[prompts_attributes][NEW_RECORD][body]" rows="2" class="block w-full rounded-xl border-2 border-slate-100 focus:border-indigo-500 focus:ring focus:ring-indigo-200 text-sm font-medium text-slate-700 placeholder-slate-300 resize-none transition-all px-4 py-3" data-content-editor-target="promptField" data-action="input->content-editor#updateCount" placeholder="Enter a prompt..."></textarea>
      
      <div class="pt-2">
        <button type="button" data-action="content-editor#removePrompt" class="text-slate-300 hover:text-red-500 p-1 opacity-0 group-hover:opacity-100 transition-all transform hover:scale-110">
          <%= lucide_icon('trash-2', class: "w-5 h-5") %>
        </button>
      </div>
    </div>
  </template>
<% end %>
