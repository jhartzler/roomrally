<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] p-4">
  <div class="max-w-md w-full">
    <div class="bg-white/10 backdrop-blur-md rounded-3xl shadow-2xl p-8 text-center space-y-6 border border-white/20">
      <div class="text-6xl mb-4">👑</div>
      <h1 class="text-4xl font-black text-white mb-2 tracking-tighter drop-shadow-lg">You're the Host!</h1>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <p class="text-blue-200 text-xs font-bold uppercase tracking-widest mb-2">Room Code</p>
        <p class="text-5xl font-black text-white font-mono tracking-wider"><%= @room.code %></p>
      </div>
      <p class="text-blue-200 font-medium">Share this code with your players so they can join!</p>
      <%= link_to "Go to Game Lobby", room_hand_path(@room.code), class: "inline-block w-full bg-blue-600 text-white font-black py-4 px-6 rounded-xl hover:bg-blue-700 active:scale-[0.98] transform hover:shadow-lg transition-all duration-200 tracking-tight" %>
    </div>
  </div>
</div>
