<div class="max-w-md mx-auto">
  <% if local_assigns[:backstage] %>
    <% if room.status == "lobby" %>
       <% if room.enough_players? %>
        <%= form_with url: start_game_room_path(room.code), method: :post, local: true, class: "space-y-4" do |f| %>
          <%= ui_card class: "p-4" do %>
            <h3 class="font-bold text-white mb-4 border-b border-white/10 pb-2">Game Settings</h3>
            <div class="flex flex-col gap-4">
              <%= render "rooms/game_settings_fields", room: room, backstage: true %>
            </div>
          <% end %>
          <%= ui_button "Start Game", nil, variant: :gradient, class: "w-full py-3", type: "submit" %>
        <% end %>
      <% else %>
        <div class="bg-warning-500/10 border border-warning-400/30 rounded-xl p-4 text-center">
          <p class="text-warning-200 font-medium">Waiting for players (<%= room.players.active_players.count %>/3)...</p>
          <p class="text-warning-300/70 text-sm mt-1">Need at least 3 players to start.</p>
        </div>
      <% end %>
    <% elsif room.current_game.present? %>
      <% game_type_folder = room.game_type.parameterize.underscore %>
      <% if lookup_context.template_exists?("host_controls", "games/#{game_type_folder}", true) %>
        <%= render "games/#{game_type_folder}/host_controls", room: room, game: room.current_game %>
      <% else %>
        <div class="bg-secondary-600/20 backdrop-blur-md border border-secondary-500/30 rounded-xl p-4 text-center shadow-lg">
          <p class="text-primary-100 font-bold text-lg tracking-wide drop-shadow-sm flex items-center justify-center gap-2">
              <span class="animate-pulse w-2 h-2 bg-secondary-400 rounded-full"></span>
              Game in Progress
          </p>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <%# Standard Host Controls (Hand View) %>
    <% if room.current_game.present? %>
      <% game_type_folder = room.game_type.parameterize.underscore %>
      <% if lookup_context.template_exists?("host_controls", "games/#{game_type_folder}", true) %>
        <%= render "games/#{game_type_folder}/host_controls", room: room, game: room.current_game %>
      <% else %>
        <div class="bg-success-100 rounded-xl p-4 text-center border border-success-200">
          <p class="text-success-700 font-bold text-lg flex items-center justify-center gap-2">
            <span class="animate-pulse w-2 h-2 bg-success-500 rounded-full"></span>
            Game in Progress
          </p>
        </div>
      <% end %>
    <% else %>
      <div class="bg-gradient-to-r from-warning-100 to-accent-100 rounded-xl p-4 mb-4 border-2 border-warning-300">
        <p class="text-center text-sm font-semibold text-neutral-700 flex items-center justify-center gap-2">
          <span>👑</span>
          <span>You're the host! Start the game when everyone's ready.</span>
        </p>
      </div>
      <% if room.enough_players? %>
        <%= form_with url: start_game_room_path(room.code), method: :post, local: true, class: "space-y-4" do |f| %>
          <div class="bg-white p-4 rounded-xl shadow-sm border border-neutral-100">
            <h3 class="font-bold text-neutral-700 mb-2">Game Settings</h3>
            <div class="flex flex-col gap-3">
              <%= render "rooms/game_settings_fields", room: room, backstage: false %>
            </div>
          </div>
          <%= ui_button "Start Game", nil, variant: :success, class: "w-full py-4 text-lg", type: "submit" %>
        <% end %>
      <% else %>
        <button class="w-full bg-neutral-300 text-neutral-500 font-bold py-4 px-6 rounded-xl cursor-not-allowed text-lg" disabled>
          Waiting for players (<%= room.players.active_players.count %>/3)...
        </button>
      <% end %>
    <% end %>
  <% end %>
</div>
