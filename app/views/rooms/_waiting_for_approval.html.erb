<%# app/views/rooms/_waiting_for_approval.html.erb %>
<%# partial locals: room, player %>
<div class="flex flex-col items-center justify-center min-h-screen p-4">
  <div class="bg-orange-500/20 backdrop-blur-md rounded-3xl p-8 border border-orange-400/50 text-center max-w-md">
    <div class="text-6xl mb-4">⏳</div>
    <h2 class="text-2xl font-bold text-white mb-4">Waiting for Approval</h2>
    <p class="text-orange-100 mb-2">You were removed by the host.</p>
    <p class="text-orange-200 text-sm mb-6">
      Change your name to a more appropriate one to get back in.
    </p>

    <div class="bg-black/20 p-4 rounded-xl mb-4">
      <p class="text-sm text-orange-300 mb-1">Current name:</p>
      <p class="text-xl font-bold text-white"><%= player.name %></p>
    </div>

    <%= link_to "Change Name", new_player_path(code: room.code),
        class: "inline-block bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg transition-all" %>
  </div>
</div>
