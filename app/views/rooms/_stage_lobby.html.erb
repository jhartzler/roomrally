<div id="stage_lobby" class="flex flex-col items-center w-full flex-1 min-h-0">
  <div id="stage_player_list" class="flex flex-wrap justify-center content-start gap-[1vh] max-w-7xl flex-1 min-h-0 overflow-hidden">
    <% @room.players.active_players.order(created_at: :desc).each do |player| %>
      <%= render "players/stage_player", player: player, room: @room %>
    <% end %>
  </div>

  <div class="mt-[2vh] animate-pulse shrink-0">
    <p class="text-vh-xl text-blue-100/90 font-bold tracking-wide drop-shadow-md">Waiting for players to join...</p>
  </div>
</div>
