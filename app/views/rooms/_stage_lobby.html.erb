<div id="stage_lobby" class="flex flex-col items-center justify-center min-h-[50vh]">
  <h2 class="text-4xl font-bold mb-12 text-white drop-shadow-md">Join via your phone!</h2>

  <div id="stage_player_list" class="flex flex-wrap justify-center gap-6 max-w-6xl">
    <% @room.players.each_with_index do |player, index| %>
      <div data-controller="player-entrance"
           data-player-entrance-index-value="<%= index %>"
           data-player-entrance-total-players-value="<%= @room.players.count %>">
        <%= render "players/stage_player", player: player %>
      </div>
    <% end %>
  </div>

  <div class="mt-16 animate-pulse">
    <p class="text-2xl text-blue-100/90 font-bold tracking-wide drop-shadow-md">Waiting for players to join...</p>
  </div>
</div>
