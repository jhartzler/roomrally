<div id="stage_lobby" class="flex flex-col items-center justify-center min-h-[50vh]">
  <h2 class="text-4xl font-bold mb-12 text-gray-300">Join via your phone!</h2>
  
  <div id="stage_player_list" class="flex flex-wrap justify-center gap-6 max-w-6xl">
    <% @room.players.each do |player| %>
      <%= render "players/stage_player", player: player %>
    <% end %>
  </div>
  
  <div class="mt-16 animate-pulse">
    <p class="text-2xl text-indigo-300">Waiting for host to start...</p>
  </div>
</div>
