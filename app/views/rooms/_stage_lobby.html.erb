<div id="stage_lobby" class="flex flex-col items-center">
  <div id="stage_player_list" class="flex flex-wrap justify-center gap-2 max-w-7xl">
    <% @room.players.active_players.order(created_at: :desc).each do |player| %>
      <%= render "players/stage_player", player: player, room: @room %>
    <% end %>
  </div>

  <div class="mt-8 animate-pulse">
    <p class="text-xl text-blue-100/90 font-bold tracking-wide drop-shadow-md">Waiting for players to join...</p>
  </div>
</div>
