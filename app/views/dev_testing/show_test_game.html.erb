<%
  action_paths = {
    start: dev_start_game_path(@room.code),
    advance: dev_advance_path(@room.code),
    bot_act: dev_bot_act_path(@room.code)
  }
  button_styles = {
    primary: "w-full py-2 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-md text-sm",
    bot: "w-full py-2 px-4 bg-green-600 hover:bg-green-700 text-white font-medium rounded-md text-sm"
  }
  badge_colors = {
    "lobby" => "bg-gray-100 text-gray-800",
    "instructions" => "bg-yellow-100 text-yellow-800",
    "finished" => "bg-blue-100 text-blue-800"
  }
  badge_default = "bg-green-100 text-green-800"
  color = badge_colors[@game_status] || badge_default
%>

<div class="flex h-screen">
  <%# Left Panel — Controls %>
  <div class="w-[350px] flex-shrink-0 bg-white border-r border-gray-200 p-6 overflow-y-auto">
    <%# Room Info %>
    <div class="mb-6">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Room</p>
      <p class="text-3xl font-bold text-indigo-600 tracking-widest"><%= @room.code %></p>
      <p class="text-sm text-gray-600 mt-1"><%= @room.game_type %></p>
    </div>

    <%# Game State %>
    <div class="mb-6">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Status</p>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium <%= color %>">
        <%= @game_status %>
      </span>
      <% if @progress_label %>
        <p class="text-sm text-gray-600 mt-1"><%= @progress_label %></p>
      <% end %>
    </div>

    <%# Action Buttons %>
    <div class="mb-6 space-y-2">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Actions</p>

      <% if @game_status == "finished" %>
        <p class="text-sm font-medium text-green-700 bg-green-50 rounded-md p-3 text-center">Game Complete!</p>
      <% else %>
        <% @dashboard_actions.each do |btn| %>
          <%= button_to btn[:label], action_paths[btn[:action]], class: button_styles[btn[:style]] %>
        <% end %>

        <div class="mt-3 border-t border-gray-200 pt-3"
             data-controller="dev-auto-play"
             data-dev-auto-play-url-value="<%= dev_auto_play_path(@room.code) %>"
             data-dev-auto-play-finished-value="<%= @game_status == 'finished' %>">
          <div class="flex items-center gap-2 mb-2">
            <input type="range" min="500" max="5000" step="500" value="2000"
                   data-dev-auto-play-target="slider"
                   data-action="input->dev-auto-play#updateInterval"
                   class="flex-1 h-1.5 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-indigo-600">
            <span data-dev-auto-play-target="label" class="text-xs text-gray-500 w-8 text-right">2.0s</span>
          </div>
          <button type="button"
                  data-dev-auto-play-target="startButton"
                  data-action="dev-auto-play#start"
                  class="w-full py-2 px-4 border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 font-medium rounded-md text-sm">
            Auto-play to End
          </button>
          <button type="button"
                  data-dev-auto-play-target="stopButton"
                  data-action="dev-auto-play#stop"
                  class="hidden w-full py-2 px-4 border border-red-300 bg-red-50 hover:bg-red-100 text-red-700 font-medium rounded-md text-sm">
            Stop Auto-play
          </button>
        </div>
      <% end %>
    </div>

    <%# Players %>
    <div class="mb-6">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Players</p>
      <div class="space-y-2">
        <% @players.each_with_index do |player, i| %>
          <div class="flex items-center justify-between bg-gray-50 p-2.5 rounded-md text-sm">
            <span class="text-gray-700 font-medium">
              <%= player.name %><%= " (host)" if i == 0 %>
            </span>
            <%= link_to "Open Hand", set_player_session_path(player), target: "_blank", class: "text-indigo-600 hover:text-indigo-800 text-xs font-medium" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Quick Links %>
    <div class="border-t border-gray-200 pt-4 space-y-2">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Quick Links</p>
      <%= link_to "Open Stage (full)", room_stage_path(@room), target: "_blank", class: "block text-sm text-indigo-600 hover:text-indigo-800" %>
      <% if current_user && @room.user == current_user %>
        <%= link_to "Open Backstage", room_backstage_path(@room), target: "_blank", class: "block text-sm text-indigo-600 hover:text-indigo-800" %>
      <% else %>
        <span class="block text-sm text-gray-400">Backstage (log in to access)</span>
      <% end %>
      <%= link_to "Create Another Game", dev_testing_path, class: "block text-sm text-indigo-600 hover:text-indigo-800" %>
    </div>
  </div>

  <%# Right Panel — Stage View %>
  <div class="flex-1">
    <iframe src="<%= room_stage_path(@room) %>" class="w-full h-full border-0"></iframe>
  </div>
</div>
