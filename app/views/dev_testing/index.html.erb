<div class="min-h-screen bg-gray-100 flex flex-col items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-xl shadow-lg">
    <h1 class="mt-6 text-center text-3xl font-extrabold text-gray-900">Dev Testing</h1>

    <%= form_with url: "/dev/testing/create_test_game", method: :post, data: { turbo: false }, class: "mt-8 space-y-6" do |form| %>
      <div class="rounded-md shadow-sm -space-y-px">
        <div>
          <%= form.label :num_players, "Number of players:", class: "sr-only" %>
          <%= form.number_field :num_players, value: 4, min: 3, class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm", placeholder: "Number of players" %>
        </div>
        <div>
          <%= form.label :game_type, "Game type:", class: "sr-only" %>
          <%= form.select :game_type, @game_types, {}, id: "game_type_select", class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-b-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm" %>
        </div>
      </div>

      <%# Pack selectors — shown/hidden by JS based on selected game type %>
      <div class="space-y-2">
        <div id="pack-selector-Speed Trivia" class="hidden">
          <%= form.label :trivia_pack_id, "Trivia Pack:", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :trivia_pack_id,
                [["— Default pack —", ""]] + @trivia_packs.map { |p| ["#{p.name}#{p.user_id.nil? ? ' (global)' : ''}", p.id] },
                { selected: "" },
                class: "mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>

        <div id="pack-selector-Write And Vote" class="hidden">
          <%= form.label :prompt_pack_id, "Prompt Pack:", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :prompt_pack_id,
                [["— Default pack —", ""]] + @prompt_packs.map { |p| ["#{p.name}#{p.user_id.nil? ? ' (global)' : ''}", p.id] },
                { selected: "" },
                class: "mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>

        <div id="pack-selector-Category List" class="hidden">
          <%= form.label :category_pack_id, "Category Pack:", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :category_pack_id,
                [["— Default pack —", ""]] + @category_packs.map { |p| ["#{p.name}#{p.user_id.nil? ? ' (global)' : ''}", p.id] },
                { selected: "" },
                class: "mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= form.submit "Create Test Game", class: "group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function () {
    var select = document.getElementById('game_type_select');
    function updatePackSelector() {
      document.querySelectorAll('[id^="pack-selector-"]').forEach(function (el) {
        el.classList.add('hidden');
      });
      var active = document.getElementById('pack-selector-' + select.value);
      if (active) active.classList.remove('hidden');
    }
    select.addEventListener('change', updatePackSelector);
    updatePackSelector();
  })();
</script>
