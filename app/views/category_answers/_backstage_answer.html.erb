<%# app/views/category_answers/_backstage_answer.html.erb %>
<div id="<%= dom_id(answer) %>" class="p-4 bg-white/5 rounded-xl border border-white/10 hover:bg-white/10 transition-colors">
  <div class="flex justify-between items-start mb-2">
    <div>
      <span class="text-[10px] uppercase font-bold text-blue-300 tracking-wider block mb-1"><%= answer.category_instance.name %></span>
    </div>
    <span class="text-[10px] uppercase font-bold text-orange-400 tracking-wider"><%= answer.player.name %></span>
  </div>

  <div class="bg-black/20 p-3 rounded-lg border border-white/5 mb-3">
    <p class="text-lg font-bold text-white"><%= answer.body %></p>
  </div>

  <div class="flex justify-end gap-2">
    <%= button_to "Reject", category_answer_path(answer), method: :patch, params: { category_answer: { status: "rejected" } }, class: "text-xs bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded-lg transition-all uppercase tracking-wide" %>
    <%= button_to "Hide from Audience", category_answer_path(answer), method: :patch, params: { category_answer: { status: "hidden" } }, class: "text-xs bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded-lg transition-all uppercase tracking-wide" %>
  </div>
</div>
