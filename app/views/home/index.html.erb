<div class="min-h-screen bg-gradient-to-br from-purple-500 via-pink-500 to-red-500 flex items-center justify-center p-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-6xl font-bold text-white mb-2">🎭</h1>
      <h1 class="text-5xl font-black text-white mb-4 drop-shadow-lg">OpenJokeMachine</h1>
      <p class="text-white text-lg opacity-90">Create laughs together</p>
      
      <div class="mt-4">
        <% if current_user %>
          <div class="flex flex-col items-center space-y-2">
            <span class="text-white text-sm">Welcome back, <%= current_user.name %>!</span>
            <%= button_to "Logout", logout_path, method: :delete, class: "text-white underline text-sm hover:text-purple-200" %>
          </div>
        <% else %>
          <%= form_with url: "/auth/google_oauth2", method: :post, data: { turbo: false } do |f| %>
            <%= f.submit "Login with Google", class: "bg-white text-gray-800 font-semibold py-2 px-4 rounded-full border border-gray-300 shadow-sm hover:bg-gray-100 transition-colors text-sm" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-2xl p-8 space-y-6">
      <%= form_with url: rooms_path, method: :post, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :game_type, "Select Game", class: "block text-gray-700 font-semibold mb-2" %>
          <%= form.select :game_type, Room::GAME_TYPES.map { |game| [game, game] }, {}, class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-all text-lg" %>
        </div>
        <%= form.submit "Create Room", class: "w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold py-4 px-6 rounded-xl hover:from-purple-700 hover:to-pink-700 transform hover:scale-105 transition-all duration-200 shadow-lg text-lg" %>
      <% end %>

      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-4 bg-white text-gray-500 font-medium">or</span>
        </div>
      </div>

      <%= form_with url: "javascript:void(0);", method: :get, data: { turbo: false, controller: "redirect-form", action: "submit->redirect-form#join", "redirect-form-url-template-value": "/rooms/{{value}}/join" }, class: "space-y-4" do |form| %>

        <div>
          <%= form.label :room_code, "Enter Room Code", class: "block text-gray-700 font-semibold mb-2" %>
          <%= form.text_field :room_code, data: { "redirect-form-target": "input" }, class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-all text-center text-2xl font-mono uppercase", placeholder: "ABCD" %>
        </div>
        <%= form.submit "Join Room", class: "w-full bg-gray-900 text-white font-bold py-4 px-6 rounded-xl hover:bg-gray-800 transform hover:scale-105 transition-all duration-200 shadow-lg" %>
      <% end %>
    </div>
  </div>
</div>
