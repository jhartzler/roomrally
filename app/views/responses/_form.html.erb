<%# app/views/responses/_form.html.erb %>
<%# partial locals: response, prompt %>
<div id="prompt-instance-<%= prompt.id %>" data-test-id="player-prompt">
  <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-white">
    <div class="bg-slate-50 px-6 py-3 border-b border-slate-100 flex justify-between items-center">
      <span class="text-slate-400 font-black text-xs uppercase tracking-widest">Active Prompt</span>
      <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
    </div>

    <div class="p-6">
      <h2 class="text-xl font-bold text-slate-900 mb-4 leading-snug"><%= prompt.body %></h2>
      
      <% if response.status == "rejected" %>
        <div class="bg-orange-500 rounded-2xl p-4 shadow-2xl shadow-orange-900/40 border-2 border-orange-400 animate-in fade-in zoom-in duration-300 mb-4">
          <div class="flex items-center gap-3 mb-1">
            <div class="bg-white rounded-full p-1">
              <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 17c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="font-black text-white text-sm uppercase tracking-tight">Revision Requested</h3>
          </div>
          <p class="text-orange-50 font-medium text-sm">
            "<%= response.rejection_reason || "Please check your answer." %>"
          </p>
        </div>
      <% end %>

      <%= form_with model: response, url: response_path(response), method: :patch, local: true do |f| %>
        <%= f.text_area :body, class: "w-full bg-slate-50 border-2 border-slate-200 rounded-2xl p-4 text-slate-900 text-lg placeholder-slate-400 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white outline-none transition-all resize-none", rows: 3, placeholder: "Type your answer...", value: (response.status == "rejected" ? response.body : "") %>
        
        <%= f.submit (response.status == "rejected" ? "Submit Revision" : "Submit Response"), class: "w-full mt-4 bg-orange-500 hover:bg-orange-600 active:scale-[0.98] text-white font-black py-4 rounded-2xl shadow-lg shadow-orange-900/20 transition-all text-lg uppercase tracking-tight cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
