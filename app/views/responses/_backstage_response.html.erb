<%# app/views/responses/_backstage_response.html.erb %>
<div id="<%= dom_id(response) %>" class="p-4 bg-white/5 rounded-xl border border-white/10 hover:bg-white/10 transition-colors">
  <div class="flex justify-between items-start mb-2">
    <div>
      <span class="text-[10px] uppercase font-bold text-blue-300 tracking-wider block mb-1">Prompt</span>
      <p class="text-sm font-medium text-white/80"><%= response.prompt_instance.body %></p>
    </div>
    <span class="text-[10px] uppercase font-bold text-orange-400 tracking-wider"><%= response.player.name %></span>
  </div>
  
  <div class="bg-black/20 p-3 rounded-lg border border-white/5 mb-3">
    <p class="text-lg font-bold text-white"><%= response.body %></p>
  </div>

  <div class="flex justify-end gap-2">
     <%= button_to "Reject", new_response_rejection_path(response), method: :get, class: "text-xs bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded-lg transition-all uppercase tracking-wide", data: { turbo_frame: "modal" } %>
  </div>
</div>
