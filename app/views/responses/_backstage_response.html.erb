<%# app/views/responses/_backstage_response.html.erb %>
<div id="<%= dom_id(response) %>" class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-100">
  <div>
    <p class="font-medium text-gray-900"><%= response.body || "Writing..." %></p>
    <p class="text-sm text-gray-500 mt-1">Prompt: <%= response.prompt_instance.body %></p>
    <p class="text-xs text-gray-400 mt-1">by <%= response.player.name %></p>
  </div>
  <div class="flex gap-2">
    <details class="group relative" data-controller="toggle">
       <summary class="list-none cursor-pointer px-3 py-1 bg-red-100 text-red-700 rounded hover:bg-red-200 text-sm font-medium transition-colors">Reject</summary>
       <div class="absolute right-0 top-full mt-2 z-10 w-72 bg-white rounded-lg shadow-xl border border-gray-200 p-4">
         <%= form_with url: response_rejections_path(response), method: :post, class: "space-y-3" do |f| %>
           <div>
             <label class="block text-xs font-semibold text-gray-700 mb-1">Reason (Optional)</label>
             <%= f.text_area :rejection_reason, rows: 2, class: "w-full text-sm border-gray-300 rounded-md focus:ring-red-500 focus:border-red-500", placeholder: "e.g. Inappropriate, off topic, etc..." %>
           </div>
           <div class="flex justify-end gap-2">
             <button type="button" class="px-2 py-1 text-xs text-gray-500 hover:text-gray-700" data-action="toggle#close">Cancel</button>
             <%= f.submit "Confirm Reject", class: "px-3 py-1 bg-red-600 text-white text-xs font-bold rounded hover:bg-red-700 cursor-pointer" %>
           </div>
         <% end %>
       </div>
    </details>
  </div>
</div>
