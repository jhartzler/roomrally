<% content_for(:title) { "RoomRally - Host Group Games Without the Stress" } %>

<div class="max-w-6xl mx-auto pb-16">
  <%# Header with Logo %>
  <header class="pt-6 px-4 mb-4 md:mb-0 flex justify-center">
    <%= link_to root_path, class: "group hover:opacity-80 transition-opacity" do %>
      <h1 class="roomrally-logo text-3xl md:text-4xl">
        Room<span>Rally</span>
      </h1>
    <% end %>
  </header>

  <%# Section 1: Hero %>
  <section class="text-center py-8 mb-16 md:mb-24">
    <div class="mb-12">
      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
        Host epic group games<br>you can get behind.
      </h1>
      <p class="text-blue-100 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed mb-10">
        An interactive game platform designed for classrooms and youth groups. Players join with their phones—you control what appears on the screen.
      </p>
      <%= link_to play_path, class: "inline-block bg-orange-500 text-white font-black py-4 px-12 rounded-full hover:bg-orange-600 active:scale-95 transform hover:shadow-2xl shadow-orange-900/40 transition-all duration-200 text-xl" do %>
        Host or Play for Free
      <% end %>
    </div>

    <%# Visual: Laptop (Host) + TV (Game) Screenshot %>
    <div class="mt-16">
      <img src="<%= "#{Rails.configuration.x.r2_assets_url}/hero-screenshot.png" %>"
           alt="Laptop showing host moderation queue next to TV displaying game with QR code"
           class="rounded-2xl shadow-2xl mx-auto max-w-full h-auto border-4 border-white/10">
    </div>
  </section>

  <%# Section 2: Customize Your Game (primary feature) %>
  <section class="bg-white/10 backdrop-blur-md rounded-3xl shadow-2xl p-10 md:p-16 border border-white/20 mb-16 md:mb-24">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Games Built for Your Group</h2>
    <p class="text-blue-100 text-lg leading-relaxed mb-8 max-w-3xl">
      Pick a game mode, add your own questions or prompts, and save it as a template for your next event — birthday party, Bible study, team meeting. RoomRally remembers your setup so you can launch in seconds.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mt-10">
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">🎮</div>
        <h3 class="text-xl font-bold text-white mb-3">Game Templates</h3>
        <p class="text-blue-200">
          Save a game configuration — type, content pack, settings — and reuse it with one click.
        </p>
      </div>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">✍️</div>
        <h3 class="text-xl font-bold text-white mb-3">Custom Prompts</h3>
        <p class="text-blue-200">
          Write Comedy Clash prompts tuned to your group's sense of humor.
        </p>
      </div>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">🧠</div>
        <h3 class="text-xl font-bold text-white mb-3">Custom Trivia</h3>
        <p class="text-blue-200">
          Add questions about topics your group actually cares about.
        </p>
      </div>
    </div>
  </section>

  <%# Section 3: The Backstage Advantage %>
  <section class="bg-white/10 backdrop-blur-md rounded-3xl shadow-2xl p-10 md:p-16 border border-white/20 mb-16 md:mb-24">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Plus, you stay in control</h2>
    <p class="text-blue-100 text-lg leading-relaxed mb-8 max-w-3xl">
      RoomRally gives you a Host Dashboard — you see every player submission before it hits the big screen. Approve the best ones, skip the rest.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mt-10">
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">✓</div>
        <h3 class="text-xl font-bold text-white mb-3">Approve or Reject</h3>
        <p class="text-blue-200">
          Filter content instantly. Keep your event appropriate and fun.
        </p>
      </div>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">🔓</div>
        <h3 class="text-xl font-bold text-white mb-3">No Accounts Needed</h3>
        <p class="text-blue-200">
          Players join via QR code. No emails, no sign-ups.
        </p>
      </div>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <div class="text-4xl mb-4">🌐</div>
        <h3 class="text-xl font-bold text-white mb-3">Browser Based</h3>
        <p class="text-blue-200">
          Works on any phone, tablet, or laptop. Nothing to install.
        </p>
      </div>
    </div>
  </section>

  <%# Section 4: How It Works %>
  <section class="bg-white/10 backdrop-blur-md rounded-3xl shadow-2xl p-10 md:p-16 border border-white/20 mb-16 md:mb-24">
    <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">How It Works</h2>
    <div class="space-y-10 max-w-3xl mx-auto">
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-full flex items-center justify-center text-white font-black text-xl">
          1
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-2">Launch</h3>
          <p class="text-blue-200 text-lg">
            Pick a game mode and start a session on your main screen.
          </p>
        </div>
      </div>

      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-full flex items-center justify-center text-white font-black text-xl">
          2
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-2">Join</h3>
          <p class="text-blue-200 text-lg">
            Players scan the QR code to enter the lobby.
          </p>
        </div>
      </div>

      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-full flex items-center justify-center text-white font-black text-xl">
          3
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-2">Curate</h3>
          <p class="text-blue-200 text-lg">
            As answers come in, you approve the best ones from your device to keep the room laughing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# Section 5: Footer / Call to Action %>
  <section class="text-center py-16 md:py-20 px-8 bg-white/5 rounded-3xl border border-white/10">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Upgrade Your Next Event.</h2>
    <p class="text-blue-200 text-lg mb-10">
      Reliable, moderated, and free to try.
    </p>
    <% if current_user %>
      <%= link_to dashboard_path, class: "inline-block bg-orange-500 text-white font-black py-4 px-12 rounded-full hover:bg-orange-600 active:scale-95 transform hover:shadow-2xl shadow-orange-900/40 transition-all duration-200 text-xl" do %>
        Go to Dashboard
      <% end %>
    <% else %>
      <%= form_with url: "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "inline-block" do |f| %>
        <%= f.submit "Create Host Account", class: "bg-orange-500 text-white font-black py-4 px-12 rounded-full hover:bg-orange-600 active:scale-95 transform hover:shadow-2xl shadow-orange-900/40 transition-all duration-200 text-xl cursor-pointer" %>
      <% end %>
    <% end %>

    <div class="mt-10 pt-8 border-t border-white/10">
      <nav class="flex flex-wrap justify-center gap-4 text-sm">
        <%= link_to "Terms of Service", terms_path, class: "text-blue-300 hover:text-orange-400 transition-colors" %>
        <span class="text-blue-300/30">|</span>
        <%= link_to "Privacy Policy", privacy_path, class: "text-blue-300 hover:text-orange-400 transition-colors" %>
      </nav>
    </div>
  </section>
</div>
