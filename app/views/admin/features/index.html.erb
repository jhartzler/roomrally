<% content_for :breadcrumb do %>
  <span class="text-sm font-semibold text-gray-700">Feature Flags</span>
<% end %>

<h1 class="text-xl font-bold mb-4">Feature Flags</h1>

<div class="space-y-3">
  <% @features.each do |feature| %>
    <div class="bg-white rounded-xl shadow-sm p-4">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="font-semibold text-gray-900"><%= feature.name.humanize %></p>
          <div class="mt-2 space-y-0.5">
            <% feature.feature_events.sort_by(&:created_at).reverse.first(3).each do |event| %>
              <p class="text-xs text-gray-400">
                <span class="<%= event.enabled? ? 'text-green-600' : 'text-red-500' %> font-medium">
                  <%= event.enabled? ? "ON" : "OFF" %>
                </span>
                · <%= event.created_at.strftime("%b %-d %-I:%M%P") %>
              </p>
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="<%= feature.enabled? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-500' %> text-xs font-bold px-2.5 py-1 rounded-full">
            <%= feature.enabled? ? "ON" : "OFF" %>
          </span>
          <%= button_to feature.enabled? ? "Turn Off" : "Turn On",
              toggle_admin_feature_path(feature),
              method: :patch,
              class: "text-xs bg-gray-100 text-gray-700 hover:bg-gray-200 font-semibold px-3 py-1 rounded-full" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
