<% info = game_info(template.game_type) %>
<div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/10 flex flex-col justify-between h-full hover:bg-white/15 transition-all group">
  <div>
    <div class="flex justify-between items-start mb-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl"><%= info[:emoji] %></span>
        <span class="text-xs font-bold text-blue-300 bg-blue-900/30 px-2 py-0.5 rounded-md border border-blue-500/20">
          <%= Room.default_display_name_for(template.game_type) %>
        </span>
      </div>
    </div>

    <h4 class="font-black text-lg text-white mb-1 group-hover:text-blue-200 transition-colors"><%= template.name %></h4>

    <p class="text-xs text-blue-300/70 mb-4">
      <% if template.pack %>
        <%= template.pack.name %>
      <% else %>
        (default prompts)
      <% end %>
    </p>
  </div>

  <div class="grid grid-cols-3 gap-2 mt-auto">
    <%= button_to launch_game_template_path(template),
      method: :post,
      class: "flex items-center justify-center gap-1.5 py-2 px-3 bg-orange-500/80 hover:bg-orange-500 text-white font-bold text-sm rounded-lg transition-colors border border-orange-400/30" do %>
      <%= lucide_icon('play', class: "w-4 h-4") %>
      Launch
    <% end %>

    <%= link_to edit_game_template_path(template),
      class: "flex items-center justify-center gap-1.5 py-2 px-3 bg-white/10 hover:bg-white/20 text-white font-bold text-sm rounded-lg transition-colors border border-white/10" do %>
      <%= lucide_icon('pencil', class: "w-4 h-4") %>
      Edit
    <% end %>

    <%= button_to duplicate_game_template_path(template),
      method: :post,
      class: "flex items-center justify-center gap-1.5 py-2 px-3 bg-white/10 hover:bg-white/20 text-white font-bold text-sm rounded-lg transition-colors border border-white/10" do %>
      <%= lucide_icon('copy', class: "w-4 h-4") %>
      Copy
    <% end %>
  </div>
</div>
