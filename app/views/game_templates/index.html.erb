<div class="min-h-screen p-6 md:p-12 font-sans text-white">
  <header class="max-w-5xl mx-auto mb-10">
    <%= link_to dashboard_path, class: "group flex items-center gap-2 text-blue-200 hover:text-white transition-colors font-bold mb-6 w-fit" do %>
      <div class="p-2 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors border border-white/10">
        <%= lucide_icon('arrow-left', class: "w-5 h-5") %>
      </div>
      <span>Back to Dashboard</span>
    <% end %>

    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-4xl font-black text-white drop-shadow-lg mb-2">My Games</h1>
        <p class="text-blue-200 font-bold tracking-widest text-sm">Saved game configurations</p>
      </div>
      <%= link_to new_game_template_path, class: "inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white font-black py-3 px-6 rounded-xl shadow-lg shadow-orange-500/30 transition-all" do %>
        <%= lucide_icon('plus', class: "w-5 h-5") %>
        Create Game
      <% end %>
    </div>
  </header>

  <main class="max-w-5xl mx-auto">
    <% if @game_templates.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @game_templates.each do |template| %>
          <%= render "template_card", template: template %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-white/10">
          <%= lucide_icon('gamepad-2', class: "w-8 h-8 text-blue-300") %>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">No saved games yet</h3>
        <p class="text-blue-200/70 text-sm mb-6">Create a game to save your favorite settings and launch with one click.</p>
        <%= link_to new_game_template_path, class: "inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white font-black py-3 px-6 rounded-xl shadow-lg shadow-orange-500/30 transition-all" do %>
          <%= lucide_icon('plus', class: "w-5 h-5") %>
          Create Your First Game
        <% end %>
      </div>
    <% end %>
  </main>
</div>
