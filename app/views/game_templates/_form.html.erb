<%= form_with(model: game_template, class: "space-y-8") do |f| %>
  <% if game_template.errors.any? %>
    <div class="bg-red-500/20 border border-red-400/30 rounded-2xl p-4">
      <h3 class="font-bold text-red-200 mb-2">Please fix the following:</h3>
      <ul class="list-disc list-inside text-red-300 text-sm space-y-1">
        <% game_template.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Name %>
  <div>
    <label class="block text-sm font-bold text-blue-200 mb-2">Game Name</label>
    <%= f.text_field :name,
      placeholder: "e.g. Friday Night Trivia, Bible Study Review",
      class: "w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-blue-300/50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <%# Game Type %>
  <div>
    <label class="block text-sm font-bold text-blue-200 mb-3">Game Type</label>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <% available_types = Room.available_game_types.dup
         if game_template.persisted? && game_template.game_type.present? && !available_types.include?(game_template.game_type)
           available_types << game_template.game_type
         end
         available_types.each do |type| %>
        <% info = game_info(type) %>
        <label class="cursor-pointer">
          <%= f.radio_button :game_type, type, class: "peer hidden", data: { action: "change->game-template-form#gameTypeChanged" } %>
          <div class="peer-checked:ring-2 peer-checked:ring-blue-500 peer-checked:bg-white/15 bg-white/5 border border-white/10 rounded-xl p-4 hover:bg-white/10 transition-all">
            <div class="text-2xl mb-1"><%= info[:emoji] %></div>
            <div class="font-bold text-white text-sm"><%= Room.default_display_name_for(type) %></div>
            <div class="text-xs text-blue-300 mt-1"><%= info[:tagline] %></div>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <%# Pack Selector %>
  <div>
    <label class="block text-sm font-bold text-blue-200 mb-2">Content Pack</label>
    <p class="text-xs text-blue-300/70 mb-3">Leave blank to use the default pack for this game type.</p>

    <div data-game-template-form-target="packSelect" data-pack-type="prompt_pack" class="<%= 'hidden' unless game_template.game_type == Room::WRITE_AND_VOTE %>">
      <%= f.select :prompt_pack_id,
        options_for_select(@prompt_packs.map { |p| [p.name, p.id] }, game_template.prompt_pack_id),
        { include_blank: "(default prompts)" },
        class: "w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <div class="mt-2">
        <%= link_to new_prompt_pack_path(return_to: request.fullpath),
          class: "text-sm text-blue-300 hover:text-white font-bold flex items-center gap-1.5 transition-colors w-fit",
          data: { action: "click->game-template-form#saveAndNavigate" } do %>
          <%= lucide_icon('plus-circle', class: "w-4 h-4", "aria-hidden": true) %>
          Create a new prompt pack
        <% end %>
      </div>
    </div>

    <div data-game-template-form-target="packSelect" data-pack-type="trivia_pack" class="<%= 'hidden' unless game_template.game_type == Room::SPEED_TRIVIA %>">
      <%= f.select :trivia_pack_id,
        options_for_select(@trivia_packs.map { |p| [p.name, p.id] }, game_template.trivia_pack_id),
        { include_blank: "(default trivia)" },
        class: "w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <div class="mt-2">
        <%= link_to new_trivia_pack_path(return_to: request.fullpath),
          class: "text-sm text-blue-300 hover:text-white font-bold flex items-center gap-1.5 transition-colors w-fit",
          data: { action: "click->game-template-form#saveAndNavigate" } do %>
          <%= lucide_icon('plus-circle', class: "w-4 h-4", "aria-hidden": true) %>
          Create a new trivia pack
        <% end %>
      </div>
    </div>

    <div data-game-template-form-target="packSelect" data-pack-type="category_pack" class="<%= 'hidden' unless game_template.game_type == Room::CATEGORY_LIST %>">
      <%= f.select :category_pack_id,
        options_for_select(@category_packs.map { |p| [p.name, p.id] }, game_template.category_pack_id),
        { include_blank: "(default categories)" },
        class: "w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <div class="mt-2">
        <%= link_to new_category_pack_path(return_to: request.fullpath),
          class: "text-sm text-blue-300 hover:text-white font-bold flex items-center gap-1.5 transition-colors w-fit",
          data: { action: "click->game-template-form#saveAndNavigate" } do %>
          <%= lucide_icon('plus-circle', class: "w-4 h-4", "aria-hidden": true) %>
          Create a new category pack
        <% end %>
      </div>
    </div>
  </div>

  <%# Settings %>
  <div>
    <label class="block text-sm font-bold text-blue-200 mb-3">Game Settings</label>
    <p class="text-xs text-blue-300/70 mb-4">These become defaults when you launch. You can still change them in the backstage.</p>

    <div class="space-y-4 bg-white/5 rounded-xl p-5 border border-white/10">
      <% settings = game_template.merged_settings %>

      <label class="flex items-center gap-3 cursor-pointer">
        <%= hidden_field_tag "game_template[settings][show_instructions]", "false" %>
        <%= check_box_tag "game_template[settings][show_instructions]", "true", settings["show_instructions"],
          class: "w-5 h-5 rounded bg-white/10 border-white/20 text-blue-500 focus:ring-blue-500" %>
        <div>
          <span class="text-white font-bold text-sm">Show Instructions</span>
          <p class="text-xs text-blue-300/70"><%= setting_description(:show_instructions) %></p>
        </div>
      </label>

      <div data-controller="checkbox-toggle">
        <label class="flex items-center gap-3 cursor-pointer">
          <%= hidden_field_tag "game_template[settings][timer_enabled]", "false" %>
          <%= check_box_tag "game_template[settings][timer_enabled]", "true", settings["timer_enabled"],
              class: "w-5 h-5 rounded bg-white/10 border-white/20 text-blue-500 focus:ring-blue-500",
              data: { checkbox_toggle_target: "checkbox", action: "change->checkbox-toggle#toggle" } %>
          <div>
            <span class="text-white font-bold text-sm">Timer</span>
            <p class="text-xs text-blue-300/70"><%= setting_description(:timer_enabled) %></p>
          </div>
        </label>

        <div class="ml-8 mt-3 <%= 'hidden' unless settings['timer_enabled'] %>" data-checkbox-toggle-target="content">
          <label class="block text-xs font-bold text-blue-300 mb-1">Timer Duration (seconds)</label>
          <%= number_field_tag "game_template[settings][timer_increment]", settings["timer_increment"],
            min: 10, max: 300, step: 5,
            class: "w-32 bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      </div>

      <label class="flex items-center gap-3 cursor-pointer">
        <%= hidden_field_tag "game_template[settings][stage_only]", "false" %>
        <%= check_box_tag "game_template[settings][stage_only]", "true", settings["stage_only"],
          class: "w-5 h-5 rounded bg-white/10 border-white/20 text-blue-500 focus:ring-blue-500" %>
        <div>
          <span class="text-white font-bold text-sm">Stage-Only Mode</span>
          <p class="text-xs text-blue-300/70">In-person mode without player phones. All interaction happens on the big screen.</p>
        </div>
      </label>

      <%# Speed Trivia specific %>
      <div data-game-template-form-target="settingsGroup" data-game-type="Speed Trivia" class="<%= 'hidden' unless game_template.game_type == Room::SPEED_TRIVIA %>">
        <label class="block text-xs font-bold text-blue-300 mb-1"><%= setting_description(:question_count) %></label>
        <%= number_field_tag "game_template[settings][question_count]", settings["question_count"],
          min: 1, max: 50,
          class: "w-32 bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <%# Category List specific %>
      <div data-game-template-form-target="settingsGroup" data-game-type="Category List" class="<%= 'hidden' unless game_template.game_type == Room::CATEGORY_LIST %>">
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-bold text-blue-300 mb-1">Total Rounds</label>
            <%= number_field_tag "game_template[settings][total_rounds]", settings["total_rounds"],
              min: 1, max: 10,
              class: "w-32 bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <label class="block text-xs font-bold text-blue-300 mb-1">Categories Per Round</label>
            <%= number_field_tag "game_template[settings][categories_per_round]", settings["categories_per_round"],
              min: 1, max: 12,
              class: "w-32 bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit game_template.persisted? ? "Save Changes" : "Create Game",
      class: "bg-orange-500 hover:bg-orange-400 text-white font-black py-3 px-8 rounded-xl shadow-lg shadow-orange-500/30 transition-all cursor-pointer" %>
    <%= link_to "Cancel", game_templates_path, class: "text-blue-300 hover:text-white font-bold transition-colors" %>
  </div>
<% end %>
